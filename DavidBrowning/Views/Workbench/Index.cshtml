@{
	ViewData["Title"] = "Theme Test";
}

<section class="wb-hero">
	<div class="container">
		<div class="row g-4 align-items-center">
			<div class="col-12 col-lg-8">
				<p class="wb-kicker">Workbench / Theme Test</p>

				<h1>
					Practical software for complex systems.
				</h1>

				<p class="wb-lede">
					This page exists to test the visual language: dark surfaces,
					structured panels, restrained accent color, readable text,
					mobile layout, and code-friendly presentation.
				</p>

				<div class="d-flex flex-wrap gap-2 mt-4">
					<a class="btn btn-primary" href="#components">
						View Components
					</a>

					<a class="btn btn-outline-primary" href="#prose">
						Read Sample Prose
					</a>
				</div>
			</div>

			<div class="col-12 col-lg-4">
				<aside class="wb-panel wb-panel-accent">
					<p class="wb-card-meta">Currently</p>

					<ul class="mb-0">
						<li>Testing the Workbench theme</li>
						<li>Checking mobile behavior</li>
						<li>Refining panels, cards, and typography</li>
					</ul>
				</aside>
			</div>
		</div>
	</div>
</section>

<section id="components" class="wb-section">
	<div class="container">
		<header class="wb-section-header">
			<p class="wb-kicker">01 / Panels</p>
			<h2>Bounded ideas with visible structure.</h2>
			<p class="wb-lede">
				Panels and cards are the main visual objects. They should feel organized,
				durable, and intentional without looking like a generic admin dashboard.
			</p>
		</header>

		<div class="row g-4">
			<div class="col-12 col-lg-4">
				<article class="wb-card h-100">
					<p class="wb-card-meta">Standard Card</p>

					<h3>Default surface</h3>

					<p class="text-secondary">
						A general-purpose card for writing previews, project summaries,
						small notes, or homepage feature blocks.
					</p>

					<ul class="wb-tag-list mt-4">
						<li class="wb-tag">Design</li>
						<li class="wb-tag">CSS</li>
						<li class="wb-tag">Bootstrap</li>
					</ul>
				</article>
			</div>

			<div class="col-12 col-lg-4">
				<article class="wb-card wb-card-accent h-100">
					<p class="wb-card-meta">Accent Card</p>

					<h3>Important item</h3>

					<p class="text-secondary">
						Accent rails should mark featured work, selected content,
						or something worth visually prioritizing.
					</p>

					<ul class="wb-tag-list mt-4">
						<li class="wb-tag">Featured</li>
						<li class="wb-tag">Case Study</li>
					</ul>
				</article>
			</div>

			<div class="col-12 col-lg-4">
				<article class="wb-card h-100">
					<p class="wb-card-meta">Writing Card</p>

					<h3>Configuration is an API</h3>

					<p class="text-secondary">
						A sample writing preview. This should be readable, scannable,
						and visually distinct without needing much decoration.
					</p>

					<a href="#">Read note</a>
				</article>
			</div>
		</div>
	</div>
</section>

<section class="wb-section">
	<div class="container">
		<header class="wb-section-header">
			<p class="wb-kicker">02 / Mixed Layout</p>
			<h2>A wider content area with a side panel.</h2>
			<p class="wb-lede">
				This tests the classic article-and-sidebar layout. On mobile, the sidebar
				should stack naturally below the main content.
			</p>
		</header>

		<div class="row g-4">
			<div class="col-12 col-lg-8">
				<div class="wb-panel">
					<div class="wb-prose">
						<h3>Main Panel</h3>

						<p>
							This is a larger panel intended for case studies, project details,
							resume sections, or longer explanations. The content should feel
							comfortable and not stretch too wide.
						</p>

						<p>
							The theme should support normal prose, <a href="#">inline hyperlinks</a>,
							muted Bootstrap text, and occasional inline code like
							<code>WebApplication.CreateBuilder(args)</code>.
						</p>

						<h3>Subsection</h3>

						<p>
							This second heading tests spacing inside prose. Long pages should feel
							structured, not like a wall of text floating in the void.
						</p>
					</div>
				</div>
			</div>

			<aside class="col-12 col-lg-4">
				<div class="wb-panel wb-panel-accent">
					<p class="wb-card-meta">Project Facts</p>

					<dl class="mb-0">
						<dt>Status</dt>
						<dd class="text-secondary">Theme prototype</dd>

						<dt>Stack</dt>
						<dd class="text-secondary">ASP.NET Core MVC</dd>

						<dt>Frontend</dt>
						<dd class="text-secondary">Bootstrap + site.css</dd>

						<dt>Goal</dt>
						<dd class="text-secondary">Professional, organized, individual</dd>
					</dl>
				</div>
			</aside>
		</div>
	</div>
</section>

<section id="prose" class="wb-section">
	<div class="container">
		<article class="wb-prose">
			<p class="wb-kicker">03 / Prose</p>

			<h2>Readable writing matters.</h2>

			<p class="wb-lede">
				This section tests long-form reading. The site should be able to host essays,
				case studies, technical notes, and project writeups without sacrificing comfort.
			</p>

			<p>
				Good internal tools expose state. Good public websites expose intent. A personal
				site should make it obvious what kind of problems the author understands, what
				tradeoffs they notice, and what kind of work they are likely to do well.
			</p>

			<p>
				The design should be calm enough for reading, structured enough for scanning,
				and distinctive enough to avoid looking like a default template.
			</p>

			<h3>A smaller heading inside prose</h3>

			<p>
				This paragraph tests vertical rhythm after a subsection heading. The line length
				should stay readable on desktop and naturally shrink on mobile.
			</p>
		</article>
	</div>
</section>

<section class="wb-section">
	<div class="container">
		<header class="wb-section-header">
			<p class="wb-kicker">04 / Code</p>
			<h2>Code blocks need to feel native to the site.</h2>
			<p class="wb-lede">
				Since the site will include technical writing, code should be readable,
				horizontally scrollable on mobile, and visually distinct from prose.
			</p>
		</header>

		<div class="wb-code-header">
			<span>C#</span>
			<span>Program.cs</span>
		</div>

<pre class="wb-code-block"><code>var builder = WebApplication.CreateBuilder(args);

builder.Services.AddControllersWithViews();

var app = builder.Build();

app.UseHttpsRedirection();
app.UseStaticFiles();

app.UseRouting();

app.MapControllerRoute(
	name: "default",
	pattern: "{controller=Home}/{action=Index}/{id?}");

app.Run();</code></pre>
	</div>
</section>

<section class="wb-section">
	<div class="container">
		<header class="wb-section-header">
			<p class="wb-kicker">05 / Forms</p>
			<h2>Future admin and contact surfaces.</h2>
			<p class="wb-lede">
				Forms are included here because they will matter later for publishing tools,
				contact pages, and admin surfaces.
			</p>
		</header>

		<div class="row g-4">
			<div class="col-12 col-lg-7">
				<form class="wb-panel">
					<div class="mb-3">
						<label for="sampleTitle" class="form-label">Title</label>
						<input id="sampleTitle"
							   class="form-control"
							   type="text"
							   placeholder="Designing a data-driven release UI" />
					</div>

					<div class="mb-3">
						<label for="sampleCategory" class="form-label">Category</label>
						<select id="sampleCategory" class="form-select">
							<option>Engineering</option>
							<option>Projects</option>
							<option>Writing</option>
							<option>Resume</option>
						</select>
					</div>

					<div class="mb-4">
						<label for="sampleBody" class="form-label">Summary</label>
						<textarea id="sampleBody"
								  class="form-control"
								  rows="5"
								  placeholder="Short summary text goes here."></textarea>
					</div>

					<div class="d-flex flex-wrap gap-2">
						<button class="btn btn-primary" type="button">
							Primary Action
						</button>

						<button class="btn btn-outline-primary" type="button">
							Secondary Action
						</button>
					</div>
				</form>
			</div>

			<div class="col-12 col-lg-5">
				<div class="wb-card wb-card-accent h-100">
					<p class="wb-card-meta">Form Notes</p>

					<h3>Admin-ready later</h3>

					<p class="text-secondary">
						This does not need to do anything yet. It is just a visual test
						for inputs, labels, buttons, spacing, and panel behavior.
					</p>

					<ul class="wb-tag-list mt-4">
						<li class="wb-tag">Forms</li>
						<li class="wb-tag">Admin</li>
						<li class="wb-tag">Future</li>
					</ul>
				</div>
			</div>
		</div>
	</div>
</section>

<section class="wb-section">
	<div class="container">
		<header class="wb-section-header">
			<p class="wb-kicker">06 / Bootstrap Compatibility</p>
			<h2>Default Bootstrap components should not look foreign.</h2>
			<p class="wb-lede">
				This section checks whether normal Bootstrap cards and buttons still fit
				inside the Workbench theme.
			</p>
		</header>

		<div class="row g-4">
			<div class="col-12 col-md-6">
				<div class="card h-100">
					<div class="card-header">
						Bootstrap Card Header
					</div>

					<div class="card-body">
						<h3 class="card-title">Standard Bootstrap card</h3>

						<p class="card-text text-secondary">
							This uses Bootstrap’s normal card classes, themed by site.css.
						</p>

						<a href="#" class="btn btn-primary">Primary</a>
						<a href="#" class="btn btn-outline-primary ms-2">Outline</a>
					</div>

					<div class="card-footer text-secondary">
						Card footer
					</div>
				</div>
			</div>

			<div class="col-12 col-md-6">
				<div class="wb-panel h-100">
					<p class="wb-card-meta">Text Samples</p>

					<p>
						Normal paragraph text should be readable against the dark background.
					</p>

					<p class="text-secondary">
						Secondary text should be muted, but not so dim that it becomes decorative.
					</p>

					<p>
						Links should be obvious: <a href="#">example hyperlink</a>.
					</p>

					<p class="mb-0">
						Inline code should work too: <code>asp-controller="Home"</code>.
					</p>
				</div>
			</div>
		</div>
	</div>
</section>