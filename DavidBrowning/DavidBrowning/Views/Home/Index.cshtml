@model DavidBrowning.Models.ViewModels.Home.IndexViewModel
@{
	ViewData["Title"] = Model.PageTitle;
}

<section class="wb-hero">
	<div class="container">
		<div class="row g-4 align-items-center">
			<div class="col">
				<p class="wb-kicker">David Browning / Software Engineer</p>
				<h1>@Model.HeroTitle</h1>
				<p class="wb-lede">
					@Model.Lede
				</p>
			</div>
		</div>
	</div>
</section>

<section class="wb-section">
	<div class="container">
		<header class="wb-section-header">
			<p class="wb-kicker">01 / Explore</p>
			<h2>Ideas worth exploring</h2>
		</header>
		<div class="row row-cols-1 row-cols-lg-4 g-4 align-items-center">
			<div class="col">
				<article class="wb-card h-100">
					<h3>
						<i class="fa-solid fa-briefcase" aria-hidden="true"></i>
						Work
					</h3>
					<p class="text-secondary">
						Lorem ipsum-style test prose
					</p>
					<a class="stretched-link" href="/work">
						See my career
					</a>
				</article>
			</div>
			<div class="col">
				<article class="wb-card h-100">
					<h3>
						<i class="fa-solid fa-diagram-project" aria-hidden="true"></i>
						Projects
					</h3>
					<p class="text-secondary">
						Lorem ipsum-style test prose
					</p>
					<a class="stretched-link" href="/projects">
						Explore projects
					</a>
				</article>
			</div>
			<div class="col">
				<article class="wb-card h-100">
					<h3>
						<i class="fa-solid fa-pen" aria-hidden="true"></i>
						Writing
					</h3>
					<p class="text-secondary">
						Lorem ipsum-style test prose
					</p>
					<a class="stretched-link" href="/writing">
						What I write
					</a>
				</article>
			</div>
			<div class="col">
				<article class="wb-card h-100">
					<h3>
						<i class="fa-solid fa-user" aria-hidden="true"></i>
						About
					</h3>
					<p class="text-secondary">
						Lorem ipsum-style test prose
					</p>
					<a class="stretched-link" href="/about">
						More about the person
					</a>
				</article>
			</div>
		</div>
	</div>
</section>

<section class="wb-section">
	<div class="container">
		<header class="wb-section-header">
			<p class="wb-kicker">02 / Selected projects</p>
			<h2>From the workbench</h2>
		</header>
		<div class="row g-4">
			<div class="col">
				<partial name="_FeaturedProjectCard" model="Model.FeaturedProject" />
			</div>
		</div>
		<div class="mt-3">
			<a href="/projects">
				View all projects
				<i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
			</a>
		</div>
	</div>
</section>

<section class="wb-section">
	<div class="container">
		<header class="wb-section-header">
			<p class="wb-kicker">03 / Recent writing</p>
			<h2>From the notebook</h2>
		</header>
		<div class="row g-4">
			<div class="col">
				<partial name="_FeaturedPostCard" model="Model.FeaturedPost" />
			</div>
		</div>
		<div class="mt-3">
			<a href="/writing">
				Browse all writing
				<i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
			</a>
		</div>
	</div>
</section>

<section class="wb-section">
	<div class="container">
		<header class="wb-section-header">
			<p class="wb-kicker">04 / In progress</p>
			<h2>On the workbench</h2>
		</header>
		<div class="row g-4">
			<div class="col">
				<partial name="_InterestCard" model="Model.WorkbenchInterest" />
			</div>
		</div>
	</div>
</section>