@model DavidBrowning.Models.ViewModels.Projects.DetailsViewModel
@{
	ViewData["Title"] = Model.ProjectName;
	var hasCaseStudy =
	   !string.IsNullOrWhiteSpace(Model.CaseStudyProblem) ||
	   !string.IsNullOrWhiteSpace(Model.CaseStudySolution) ||
	   !string.IsNullOrWhiteSpace(Model.CaseStudyResult) ||
	   !string.IsNullOrWhiteSpace(Model.CaseStudyTradeoffs);
}

<section class="wb-hero">
	<div class="container">
		<div class="row g-4 align-items-center">
			<div class="col">
				@* Use these kickers if a page is broken into many sections *@
				<p class="wb-kicker">Projects</p>
				<h1>
					@Model.ProjectName
				</h1>

				<p class="wb-lede">
					@Model.Description
				</p>
			</div>
		</div>

		<div class="row g-4">
			<div class="col">
				<dl class="mb-0">
					<dt>Status</dt>
					<dd class="text-secondary">@Model.ProjectStatus</dd>
				</dl>
			</div>
			<div class="col">
				<dl class="mb-0">
					<dt>Type</dt>
					<dd class="text-secondary">@Model.ProjectType</dd>
				</dl>
			</div>
			<div class="col">
				<dl class="mb-0">
					<dt>Origin</dt>
					<dd class="text-secondary">@Model.ProjectOrigin</dd>
				</dl>
			</div>
			<div class="col">
				<dl class="mb-0">
					<dt>Duration</dt>
					<dd class="text-secondary">@Model.DateDisplayText</dd>
				</dl>
			</div>
		</div>

		@if (!string.IsNullOrEmpty(Model.Role))
		{
			<div class="row g-4 cols-2">
				<div class="col-4">
					<dl class="mb-0">
						<dt>Role</dt>
						<dd class="text-secondary">@Model.Role</dd>
					</dl>
				</div>
				<div class="col-8">
					<dl class="mb-0">
						<dt>Contribution</dt>
						<dd class="text-secondary">@Model.ContributionSummary</dd>
					</dl>
				</div>
			</div>
		}

		<div class="row g-4">
			<div class="col">
				<aside class="wb-panel wb-panel-accent">
					<p class="wb-card-meta">Tags:</p>
					<ul class="wb-tag-list mt-4">
						@foreach (var tag in Model.TagLinks)
						{
							var m = new DavidBrowning.Models.ViewModels.QueryTagViewModel()
							{
								Controller = "projects",
								Endpoint = "tags",
								DisplayName = tag.ProjectTag!.DisplayName,
								Slug = tag.ProjectTag!.Slug,
							};

							<partial name="_QueryTag" model="@m" />
						}
					</ul>
				</aside>
			</div>

			<div class="row g-4">
				<div class="col">
					<aside class="wb-panel wb-panel-accent">
						<p class="wb-card-meta">Technologies:</p>
						<ul class="wb-tag-list mt-4">
							@foreach (var tag in Model.StackTagLinks)
							{
								var m = new DavidBrowning.Models.ViewModels.QueryTagViewModel()
								{
									Controller = "projects",
									Endpoint = "stacks",
									DisplayName = tag.ProjectStackTag!.DisplayName,
									Slug = tag.ProjectStackTag!.Slug,
								};
								<partial name="_QueryTag" model="@m" />
							}
						</ul>
					</aside>
				</div>
			</div>
		</div>
	</div>
</section>

@if (Model.AssetBlocks.Count > 0)
{
	<section id="details" class="wb-section">
		<div class="container">
			<header class="wb-section-header">
				@* Use these kickers if a page is broken into many sections *@
				@* <p class="wb-kicker">Projects</p> *@
				<h2>Project Details</h2>
				@* <p class="wb-lede"></p> *@
			</header>

			<div class="row row-cols-1 g-4">
				@foreach (var asset in Model.AssetBlocks)
				{
					<partial name="_AssetBlock" model="@asset" />
				}
			</div>
		</div>
	</section>
}

@if (hasCaseStudy)
{
	<section class="wb-section">
		<p class="wb-section-kicker">Case Study</p>
		<h2>How the project came together</h2>

		<div class="wb-case-study">
			@if (!string.IsNullOrWhiteSpace(Model.CaseStudyProblem))
			{
				<article class="wb-case-study-section">
					<h3>Problem</h3>
					<p>@Model.CaseStudyProblem</p>
				</article>
			}

			@if (!string.IsNullOrWhiteSpace(Model.CaseStudySolution))
			{
				<article class="wb-case-study-section">
					<h3>Approach</h3>
					<p>@Model.CaseStudySolution</p>
				</article>
			}

			@if (!string.IsNullOrWhiteSpace(Model.CaseStudyResult))
			{
				<article class="wb-case-study-section">
					<h3>Result</h3>
					<p>@Model.CaseStudyResult</p>
				</article>
			}

			@if (!string.IsNullOrWhiteSpace(Model.CaseStudyTradeoffs))
			{
				<article class="wb-case-study-section">
					<h3>Tradeoffs</h3>
					<p>@Model.CaseStudyTradeoffs</p>
				</article>
			}
		</div>
	</section>
}

@if (Model.Links.Count > 0)
{
	<section id="links" class="wb-section">
		<div class="container">
			<header class="wb-section-header">
				@* Use these kickers if a page is broken into many sections *@
				@* <p class="wb-kicker">Projects</p> *@
				<h2>Project Links</h2>
				<p class="wb-lede">Links to project resources.</p>
			</header>

			<div class="row row-cols-1 g-4">
				<div class="col">
					<aside class="wb-panel wb-panel-accent">
						<p class="wb-card-meta">Tags:</p>
						<ul class="wb-tag-list mt-4">
							@foreach (var link in Model.Links)
							{
								var linkClass = string.Empty;
								if (link.IsPrimary)
								{
								}
								<li class="wb-tag">
									<a class="wb-footer-link link-danger @linkClass"
									   href="@link.Url" target="_blank" rel="noopener noreferrer">
										@if (!string.IsNullOrEmpty(link.ProjectLinkType!.IconCssClass))
										{
											<i class="@link.ProjectLinkType!.IconCssClass" aria-hidden="true"></i>
										}
										<span>@link.Label</span>
									</a>
								</li>
							}
						</ul>
					</aside>
				</div>
			</div>
		</div>
	</section>
}

@if (Model.RelatedPosts.Count > 0)
{
	<section id="related" class="wb-section">
		<div class="container">
			<header class="wb-section-header">
				<h2>Also Read</h2>
			</header>
			<div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 row-cols-xxl-5 g-4">
				@foreach (var post in Model.RelatedPosts)
				{
					<div class="col">
						<partial name="_FeaturedPostCard" model="post.Post" />
					</div>
				}
			</div>
		</div>
	</section>
}