@model DavidBrowning.Models.ViewModels.Projects.DetailsViewModel
@{
	ViewData["Title"] = Model.ProjectName;
}

<section class="wb-hero">
	<div class="container">
		<div class="row g-4 align-items-center">
			<div class="col">
				<p class="wb-kicker">Projects / @Model.ProjectType</p>
				<h1>@Model.ProjectName</h1>
				<p class="wb-lede">@Model.Description</p>
			</div>
		</div>

		<div class="row row-cols-2 row-cols-lg-4 g-4 mt-4">
			<div class="col">
				<dl class="mb-0">
					<dt>Status</dt>
					<dd class="text-secondary">@Model.ProjectStatus</dd>
				</dl>
			</div>
			<div class="col">
				<dl class="mb-0">
					<dt>Type</dt>
					<dd class="text-secondary">@Model.ProjectType</dd>
				</dl>
			</div>
			<div class="col">
				<dl class="mb-0">
					<dt>Origin</dt>
					<dd class="text-secondary">@Model.ProjectOrigin</dd>
				</dl>
			</div>
			<div class="col">
				<dl class="mb-0">
					<dt>Duration</dt>
					<dd class="text-secondary">@Model.DateDisplayText</dd>
				</dl>
			</div>
		</div>

		@if (!string.IsNullOrEmpty(Model.Role))
		{
			<div class="row g-4 mt-4">
				<div class="col-12 col-lg-4">
					<dl class="mb-0">
						<dt>Role</dt>
						<dd class="text-secondary">@Model.Role</dd>
					</dl>
				</div>

				<div class="col-12 col-lg-8">
					<dl class="mb-0">
						<dt>Contribution</dt>
						<dd class="text-secondary">@Model.ContributionSummary</dd>
					</dl>
				</div>
			</div>
		}

		<div class="row row-cols-1 row-cols-lg-2 g-4 mt-4">
			<div class="col">
				<aside class="wb-panel wb-panel-accent h-100">
					<p class="wb-card-meta">Tags</p>

					<ul class="wb-tag-list">
						@foreach (var tag in Model.TagLinks)
						{
							var m =
							new DavidBrowning.Models.ViewModels.QueryTagViewModel()
							{
								Controller = "projects",
								Endpoint = "tags",
								DisplayName = tag.ProjectTag!.DisplayName,
								Slug = tag.ProjectTag!.Slug,
							};

							<partial name="_QueryTag" model="@m" />
						}
					</ul>
				</aside>
			</div>

			<div class="col">
				<aside class="wb-panel wb-panel-accent h-100">
					<p class="wb-card-meta">Technologies</p>

					<ul class="wb-tag-list">
						@foreach (var tag in Model.StackTagLinks)
						{
							var m =
							new DavidBrowning.Models.ViewModels.QueryTagViewModel()
							{
								Controller = "projects",
								Endpoint = "stacks",
								DisplayName = tag.ProjectStackTag!.DisplayName,
								Slug = tag.ProjectStackTag!.Slug,
							};

							<partial name="_QueryTag" model="@m" />
						}
					</ul>
				</aside>
			</div>
		</div>
	</div>
</section>

@if (Model.Body is not null)
{
	<section class="wb-section">
		<div class="container">
			<header class="wb-section-header">
				<p class="wb-kicker">Case study</p>
				<h2>Project details</h2>
			</header>
			<partial name="_RenderedContent" model="Model.Body" />
		</div>
	</section>
}

@if (Model.AssetBlocks.Count > 0)
{
	<section class="wb-section">
		<div class="container">
			<header class="wb-section-header">
				<p class="wb-kicker">Visuals</p>
				<h2>Screenshots and diagrams</h2>
			</header>

			<div class="d-grid gap-4">
				@foreach (var asset in Model.AssetBlocks)
				{
					<partial name="_AssetBlock" model="asset" />
				}
			</div>
		</div>
	</section>
}

@if (Model.Links.Count > 0)
{
	<section class="wb-section">
		<div class="container">
			<header class="wb-section-header">
				<p class="wb-kicker">Resources</p>
				<h2>Project links</h2>
			</header>

			<aside class="wb-panel wb-panel-accent">
				<p class="wb-card-meta">Links</p>

				<ul class="wb-tag-list">
					@foreach (var link in Model.Links)
					{
						<li class="wb-tag">
							<a class="wb-footer-link"
							   href="@link.Url"
							   target="_blank"
							   rel="noopener noreferrer">
								@if (!string.IsNullOrEmpty(
														link.ProjectLinkType!.IconCssClass))
								{
									<i class="@link.ProjectLinkType.IconCssClass"
									   aria-hidden="true"></i>
								}

								<span>@link.Label</span>
							</a>
						</li>
					}
				</ul>
			</aside>
		</div>
	</section>
}

@if (Model.RelatedPosts.Count > 0)
{
	<section class="wb-section">
		<div class="container">
			<header class="wb-section-header">
				<p class="wb-kicker">Further reading</p>
				<h2>Also read</h2>
			</header>

			<div class="wb-featured-grid">
				@foreach (var post in Model.RelatedPosts)
				{
					<partial name="_FeaturedPostCard" model="post.Post" />
				}
			</div>
		</div>
	</section>
}