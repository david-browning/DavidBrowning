@model DavidBrowning.Models.ViewModels.Projects.IndexViewModel
@{
	ViewData["Title"] = Model.PageTitle;
}

<section class="wb-hero">
	<div class="container">
		<div class="row g-4 align-items-center">
			<div class="col">
				<p class="wb-kicker">@Model.PageTitle</p>
				<h1>@Model.HeroTitle</h1>
				<p class="wb-lede">
					@Model.HeroSubtitle
				</p>
			</div>
		</div>
	</div>
</section>

<section id="featured" class="wb-section">
	<div class="container">
		<header class="wb-section-header">
			<p class="wb-kicker">01 / Selected Work</p>
			<h2>Featured projects</h2>
			@* <p class="wb-lede"></p> *@
		</header>
		<div class="wb-featured-grid">
			@foreach (var project in Model.FeaturedProjects)
			{
				<div class="col">
					<partial name="_FeaturedProjectCard" model="project" />
				</div>
			}
		</div>
	</div>
</section>

<section id="all" class="wb-section">
	<div class="container">
		<header class="wb-section-header">
			<p class="wb-kicker">02 / Project Catalog</p>
			<h2>All projects</h2>
			@* <p class="wb-lede"></p> *@
		</header>

		<div class="row row-cols-1 g-4">
			@foreach (var project in Model.AllProjects)
			{
				<div class="col">
					<partial name="_ProjectCard" model="project" />
				</div>
			}
		</div>
	</div>
</section>