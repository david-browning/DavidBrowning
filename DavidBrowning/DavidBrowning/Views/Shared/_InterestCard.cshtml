@model DavidBrowning.Models.ViewModels.InterestCardViewModel
@{
	var icoClass = $"fa-solid {Model.IconCssClass} fa-2xl icon-accent";
}
<article class="wb-card h-100">
	<h3>@Model.Title</h3>
	<div class="container">
		<div class="row">
			<div class="col">
				<div class="d-flex align-items-center gap-3">
					<i class="@icoClass" aria-hidden="true"></i>
					<p class="text-secondary mb-0">
						@Model.Description
					</p>
				</div>
			</div>
		</div>
		@if (Model.Image != null)
		{
			<div class="row">
				<div class="col">
					<partial name="_RenderedContent" model="@Model.Image" />
				</div>
			</div>
		}
	</div>
</article>