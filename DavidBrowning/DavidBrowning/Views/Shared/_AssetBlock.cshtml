@model DavidBrowning.Models.ViewModels.AssetBlockViewModel
@inject DavidBrowning.Services.UrlBuilder urlBuilder

@if (Model.AssetType == DavidBrowning.Models.SiteAssetType.Image)
{
    <figure class="wb-asset-block wb-asset-block-image">
        <img src="@urlBuilder.GetContentUrl(Model.AssetKey)"
             alt="@Model.AltText"
             loading="lazy" />

        @if (!string.IsNullOrWhiteSpace(Model.Caption))
        {
            <figcaption>@Model.Caption</figcaption>
        }
    </figure>
}