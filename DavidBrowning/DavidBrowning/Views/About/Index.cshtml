@model DavidBrowning.Models.ViewModels.About.IndexViewModel
@{
	ViewData["Title"] = Model.PageTitle;
}

<section class="wb-hero">
	<div class="container">
		<div class="row g-4 align-items-center">
			<div class="col">
				<p class="wb-kicker">@Model.PageTitle</p>
				<h1>@Model.HeroTitle</h1>
				<p class="wb-lede">@Model.HeroSubtitle</p>
			</div>
		</div>
	</div>
</section>

<section class="wb-section">
	<div class="container">
		<div class="row g-4 align-items-center">
			<div class="col">
				<p class="wb-kicker">01 / Background</p>
				<h2>A little about me</h2>
			</div>
			<div class="row g-4 mt-4">
				<div class="col-12 col-lg-8">
					<p class="wb-lede mb-0">
						@Model.AboutMe
					</p>
				</div>
				<div class="col-12 col-lg-4">
					<partial name="_RenderedContent" model="@Model.MeImage" />
				</div>
			</div>
		</div>
</section>

<section id="interests" class="wb-section">
	<div class="container">
		<header class="wb-section-header">
			<p class="wb-kicker">02 / Beyond the Code</p>
			<h2>Interests</h2>
			@* <p class="wb-lede"></p> *@
		</header>

		<div class="row row-cols-1 g-4">
			@foreach (var interest in Model.Interests)
			{
				<div class="col">
					<partial name="_InterestCard" model="interest" />
				</div>
			}
		</div>
	</div>
</section>