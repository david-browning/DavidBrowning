@model DavidBrowning.Models.ViewModels.Writing.IndexViewModel
@{
	ViewData["Title"] = "Writing";
}

<section class="wb-hero">
	<div class="container">
		<div class="row g-4 align-items-center">
			<div class="col">
				<p class="wb-kicker">@Model.PageTitle</p>
				<h1>@Model.HeroTitle</h1>
				<p class="wb-lede">
					@Model.HeroSubtitle
				</p>
			</div>
		</div>
	</div>
</section>

@if (Model.ShowFeaturedPosts)
{
	<section class="wb-section">
		<div class="container">
			<header class="wb-section-header">
				<p class="wb-kicker">01 / Highlights</p>
				<h2>Featured writing</h2>
				@* <p class="wb-lede"></p> *@
			</header>
			<div class="wb-featured-grid">
				@foreach (var post in Model.FeaturedPosts)
				{
					<div class="col">
						<partial name="_FeaturedPostCard" model="post" />
					</div>
				}
			</div>
		</div>
	</section>
}

<section class="wb-section">
	<div class="container">
		<header class="wb-section-header">
			<p class="wb-kicker">02 / Archive</p>
			<h2>All writing</h2>
			@* <p class="wb-lede"></p> *@
		</header>

		<div class="row row-cols-1 g-4">
			@foreach (var post in Model.Posts)
			{
				<div class="col">
					<partial name="_PostCard" model="post" />
				</div>
			}
		</div>
		<partial name="_Pager" model="Model.Pager" />
	</div>
</section>