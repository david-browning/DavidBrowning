{
   "Logging": {
      "LogLevel": {
         "Default": "Information",
         "Microsoft.AspNetCore": "Warning",
         "Microsoft.EntityFrameworkCore": "Warning",
         "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
   },
   "AllowedHosts": "*",
   "Stores": {
      "WritingStore": {
         "Provider": "SqlServer"
      },
      "ProjectStore": {
         "Provider": "SqlServer"
      },
      "ErrorStore": {
         "Provider": "SqlServer"
      },
      "LookupStore": {
         "Provider": "SqlServer"
      },
      "ContentStore": {
         "Provider": "AzureStorageBlobs"
      }
   },
   "Secrets": {
      "Provider": "AzureKeyVault"
   },
   "Database": {
      "Provider": "SqlServer",
      "TablePrefix": "db_",
      "Seed": {
         "Enabled": false
      }
   },
   "KeyVault": {
      "Uri": ""
   },
   "Diagnostics": {
      "EnableDebugEndpoints": false,
      "EnableCustomerErrors": true,
      "EntityFrameworkOptions": {
         "EnableSensitiveDataLogging": false,
         "EnableDetailedErrors": false,
         "EnableSqlCommandLogging": false
      }
   },
   "Cache": {
      "EnableContentCache": true,
      "SlugCache": {
         "CacheDuration": 60,
         "CacheTimeout": 10,
         "TrackCacheStatistics": true,
         "ObjectCacheSize": 33554432
      },
      "JsonCache": {
         "CacheDuration": 60,
         "CacheTimeout": 10,
         "TrackCacheStatistics": true,
         "ObjectCacheSize": 128
      },
      "RenderedContentCache": {
         "CacheDuration": 60,
         "CacheTimeout": 10,
         "TrackCacheStatistics": true,
         "ObjectCacheSize": 33554432
      }
   },
   "Content": {
      "CardCollectionLength": 3
   },
   "DateTimeDisplayOptions": {
      "TimeZoneId": "America/Los_Angeles"
   },
   "FeaturedProjectSlug": "personal-website",
   "FeaturePostSlug": "the-four-fs-of-code"
}
