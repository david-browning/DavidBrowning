{
   "Logging": {
      "LogLevel": {
         "Default": "Information",
         "Microsoft.AspNetCore": "Warning"
      }
   },
   "AllowedHosts": "*",
   "Stores": {
      "WritingStore": {
         "Provider": "AzureSql"
      },
      "ErrorStore": {
         "Provider": "AzureSql"
      },
      "LookupStore": {
         "Provider": "AzureSql"
      }
   },
   "Diagnostics": {
      "Error": {
         "Enabled": false,
         "PageSize": 50
      },
      "Home": {
         "Enabled": false
      },
      "Writing": {
         "Enabled": false,
         "PageSize": 10
      }
   },
   "LookupCache": {
      "CacheDuration" : 60
   }
}
