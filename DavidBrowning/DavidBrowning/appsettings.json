{
   "Logging": {
      "LogLevel": {
         "Default": "Information",
         "Microsoft.AspNetCore": "Warning",
         "Microsoft.EntityFrameworkCore": "Warning",
         "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
   },
   "AllowedHosts": "*",
   "Stores": {
      "WritingStore": {
         "Provider": "SqlServer"
      },
      "ProjectStore": {
         "Provider": "SqlServer"
      },
      "ErrorStore": {
         "Provider": "SqlServer"
      },
      "LookupStore": {
         "Provider": "SqlServer"
      }
   },
   "Secrets": {
      "Provider": "AzureKeyVault"
   },
   "Database": {
      "Provider": "SqlServer",
      "TablePrefix": "db_",
      "Seed": {
         "Enabled": false
      }
   },
   "KeyVault": {
      "Uri": ""
   },
   "Diagnostics": {
      "EnableDebugEndpoints": false,
      "EnableCustomerErrors" : true,
      "EntityFrameworkOptions": {
         "EnableSensitiveDataLogging": false,
         "EnableDetailedErrors": false,
         "EnableSqlCommandLogging": false
      }
   },
   "LookupCache": {
      "CacheDuration": 60
   },
   "Content": {
      "CardCollectionLength": 3
   }
}
