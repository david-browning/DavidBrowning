{
   "Logging": {
      "LogLevel": {
         "Default": "Information",
         "Microsoft.AspNetCore": "Warning"
      }
   },
   "Stores": {
      "WritingStore": {
         "Provider": "Dummy"
      },
      "ErrorStore": {
         "Provider": "Dummy"
      }
   },
   "Diagnostics": {
