{
   "Logging": {
      "LogLevel": {
         "Default": "Information",
         "Microsoft.AspNetCore": "Warning",
         "Microsoft.EntityFrameworkCore.Database.Command": "Information",
         "Microsoft.EntityFrameworkCore.Infrastructure": "Warning"
      }
   },
   "Stores": {
      "WritingStore": {
         "Provider": "SqlServer"
      },
      "ProjectStore": {
         "Provider": "SqlServer"
      },
      "ErrorStore": {
         "Provider": "SqlServer"
      },
      "LookupStore": {
         "Provider": "SqlServer"
      }
   },
   "Secrets": {
      "Provider": "Local"
   },
   "Database": {
      "Provider": "InMemory",
      "TablePrefix": "db_",
      "InMemoryDatabaseName": "DavidBrowning",
      "Seed": {
         "Enabled": true,
         "RootFolder": "Data/Seeding/DataFiles",
         "SkipFileWhenTargetTableHasRows": true,
         "ThrowOnUnmatchedJsonFiles": true,
         "UseSqlServerIdentityInsertWhenNeeded": true
      }
   },
   "KeyVault": {
      "Uri": ""
   },
   "Diagnostics": {
      "EnableDebugEndpoints": true,
      "EnableCustomerErrors": false,
      "EntityFrameworkOptions": {
         "EnableSensitiveDataLogging": true,
         "EnableDetailedErrors": true,
         "EnableSqlCommandLogging": false
      }
   },
   "LookupCache": {
      "CacheDuration": 5
   },
   "Content": {
      "CardCollectionLength": 3
   }
}
