{
   "Logging": {
      "LogLevel": {
         "Default": "Information",
         "Microsoft.AspNetCore": "Warning",
         "Microsoft.EntityFrameworkCore.Database.Command": "Information",
         "Microsoft.EntityFrameworkCore.Infrastructure": "Warning"
      }
   },
   "Stores": {
      "WritingStore": {
         "Provider": "SqlServer"
      },
      "ProjectStore": {
         "Provider": "SqlServer"
      },
      "ErrorStore": {
         "Provider": "SqlServer"
      },
      "LookupStore": {
         "Provider": "SqlServer"
      },
      "ContentStore": {
         "Provider": "AzureStorageBlobs",
         "AzureStorageBlobs": {
            "ServiceUri": "https://stdavidbrowningprod.blob.core.windows.net",
            "ContainerName": "content"
         }
      }
   },
   "Secrets": {
      "Provider": "Local"
   },
   "Database": {
      "Provider": "SqlServer",
      "ConnectionName": "AzureSiteDatabase",
      "TablePrefix": "db_",
      "ConnectTimeoutSeconds": 5,
      "CommandTimeoutSeconds": 5,
      "RetryCount": 0,
      "MaxRetryDelaySeconds": 2,
      "InMemoryDatabaseName": "DavidBrowning",
      "Seed": {
         "Enabled": false,
         "RootFolder": "Data/Seeding/DataFiles",
         "SkipFileWhenTargetTableHasRows": true,
         "ThrowOnUnmatchedJsonFiles": true,
         "UseSqlServerIdentityInsertWhenNeeded": true
      }
   },
   "KeyVault": {
      "VaultUri": "https://kv-davidbrowning-website.vault.azure.net/"
   },
   "Diagnostics": {
      "EnableDebugEndpoints": true,
      "EnableCustomErrors": false,
      "EntityFrameworkOptions": {
         "EnableSensitiveDataLogging": true,
         "EnableDetailedErrors": true,
         "EnableSqlCommandLogging": false
      },
      "Warmup": {
         "Enabled": true,
         "MinimumInterval": "00:30:00",
         "MaximumWaitTime": "00:02:00",
         "RetryDelay": "00:00:05",
         "AttemptConnectTimeoutSeconds": 5,
         "AttemptCommandTimeoutSeconds": 5
      }
   },
   "Publication": {
      "ManifestKey": "published/current.json",
      "SnapshotPrefix": "published/snapshots"
   },
   "Cache": {
      "EnableContentCache": true,
      "OutputCacheDuration": "12:00:00",
      "SitemapCacheDuration": "1.00:00:00",
      "SlugCache": {
         "CacheDuration": "01:00:00",
         "CacheTimeout": "00:10:00",
         "TrackCacheStatistics": true,
         "ObjectCacheSize": 33554432
      },
      "JsonCache": {
         "CacheDuration": "01:00:00",
         "CacheTimeout": "00:10:00",
         "TrackCacheStatistics": true,
         "ObjectCacheSize": 33554432
      },
      "RenderedContentCache": {
         "CacheDuration": "01:00:00",
         "CacheTimeout": "00:10:00",
         "TrackCacheStatistics": true,
         "ObjectCacheSize": 33554432
      }
   },
   "Content": {
      "CardCollectionLength": 3,
      "PageSize": 25
   },
   "DateTimeDisplayOptions": {
      "TimeZoneId": "America/Los_Angeles"
   },
   "MetadataOptions": {
      "AuthorName": "David Browning"
   },
   "FeaturedProjectSlug": "personal-website",
   "FeaturePostSlug": "the-four-fs-of-code"
}
