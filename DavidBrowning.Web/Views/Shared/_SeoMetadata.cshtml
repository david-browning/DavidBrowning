@using System.Text.Json
@model DavidBrowning.Web.ViewModels.SeoMetadataViewModel

<title>@Model.Title - David Browning</title>

@if (!string.IsNullOrWhiteSpace(Model.Description))
{
	<meta name="description" content="@Model.Description">
}

@if (!string.IsNullOrWhiteSpace(Model.CanonicalUrl))
{
	<link rel="canonical" href="@Model.CanonicalUrl">
}

@if (Model.NoIndex)
{
	<meta name="robots" content="noindex">
}
else
{
	<meta property="og:title" content="@Model.Title - David Browning">

	@if (!string.IsNullOrWhiteSpace(Model.Description))
	{
		<meta property="og:description" content="@Model.Description">
	}

	@if (!string.IsNullOrWhiteSpace(Model.CanonicalUrl))
	{
		<meta property="og:url" content="@Model.CanonicalUrl">
	}

	<meta property="og:type" content="@Model.OpenGraphType">

	@if (!string.IsNullOrWhiteSpace(Model.PreviewImageUrl))
	{
		<meta property="og:image" content="@Model.PreviewImageUrl">
	}
}

@if (Model.StructuredData is not null)
{
	<script type="application/ld+json">
		@Html.Raw(JsonSerializer.Serialize(Model.StructuredData))
	</script>
}