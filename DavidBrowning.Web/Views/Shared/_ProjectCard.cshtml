@*
	A project card is a wide (takes up the whole width) card with the overview
	and key details of a project.
*@
@model DavidBrowning.Models.Projects.Project
@inject DavidBrowning.Infrastructure.UrlBuilder urlBuilder

<article class="wb-card h-100 d-flex flex-column">
	<p class="wb-card-meta">@Model.ProjectType!.DisplayName</p>
	<h3>@Model.Name</h3>
	<p class="wb-card-meta">Project Facts</p>
	<div class="row row-cols-1 row-cols-md-2 g-3">
		<div class="col">
			<dl class="mb-0">
				<dt>Status</dt>
				<dd class="text-secondary">@Model.ProjectStatus!.DisplayName</dd>
			</dl>
		</div>
		<div class="col">
			<dl class="mb-0">
				<dt>Origin</dt>
				<dd class="text-secondary">@Model.ProjectOrigin!.DisplayName</dd>
			</dl>
		</div>
	</div>

	<p class="text-secondary">
		@Model.Description
	</p>

	<p class="text-secondary">
		@Model.ContributionSummary
	</p>

	<div class="mt-4">
		<ul class="wb-tag-list">
			@foreach (var tag in Model.StackTagLinks)
			{
				var m = new DavidBrowning.Web.ViewModels.QueryTagViewModel()
				{
					Controller = "projects",
					Endpoint = "stacks",
					DisplayName = tag.ProjectStackTag!.DisplayName,
					Slug = tag.ProjectStackTag!.Slug,
				};

				<partial name="_QueryTag" model="@m" />
			}
		</ul>
	</div>

	<div class="mt-auto pt-4">
		<a href="@urlBuilder.GetDetailsUrl(Model.Slug, "projects")">
			More
			<i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
		</a>
	</div>
</article>
