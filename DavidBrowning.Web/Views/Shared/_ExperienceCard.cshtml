@model DavidBrowning.Web.ViewModels.Work.ExperienceViewModel

<article class="wb-card h-100 d-flex flex-column">
	@if (!string.IsNullOrEmpty(Model.LocationDisplayText))
	{
		<p class="wb-card-meta">@Model.LocationDisplayText</p>
	}
	<h3>@Model.CompanyName</h3>
	<div class="container">
		@foreach (var role in Model.Roles)
		{
			<div class="mt-4">
				<div class="d-flex justify-content-between gap-3">
					<h4>@role.Title</h4>

					@if (!string.IsNullOrEmpty(role.DateDisplayText))
					{
						<span class="text-secondary text-end">
							@role.DateDisplayText
						</span>
					}
				</div>

				<p>@role.Description</p>

				<ul>
					@foreach (var bullet in role.Bullets)
					{
						<li>@bullet</li>
					}
				</ul>
			</div>
		}
	</div>
</article>