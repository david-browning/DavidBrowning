@model DavidBrowning.Web.ViewModels.InterestCardViewModel
@inject DavidBrowning.Infrastructure.UrlBuilder urlBuilder
@{
	var icoClass = $"fa-solid {Model.IconCssClass} fa-2xl icon-accent";
}
<article class="wb-card h-100">
	<h3>@Model.Title</h3>

	<div class="d-flex align-items-center gap-3">
		<i class="@icoClass" aria-hidden="true"></i>

		<p class="text-secondary mb-0">
			@Model.Summary
		</p>
	</div>

	@if (Model.FeaturedPost is not null)
	{
		var url = urlBuilder.GetDetailsUrl(Model.FeaturedPost!.Slug, "writing");
		<div class="mt-auto pt-3 pl-3">
@* 			<p class="wb-kicker mb-2">
				Featured writing
			</p> *@

			<a class="wb-card-link"
			   href="@url">
				@Model.FeaturedPost.Title
			</a>

			@if (!string.IsNullOrWhiteSpace(Model.FeaturedPost.Summary))
			{
				<p class="text-secondary small mt-2 mb-0">
					@Model.FeaturedPost.Summary
				</p>
			}
		</div>
	}

	@if (Model.Image is not null)
	{
		<div class="mt-4">
			<partial name="_RenderedContent" model="Model.Image" />
		</div>
	}
</article>