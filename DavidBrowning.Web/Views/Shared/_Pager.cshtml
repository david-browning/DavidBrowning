@model DavidBrowning.Web.ViewModels.PagerViewModel

@{
	string GetPageUrl(int page)
	{
		var url = page == 1
		   ? Url.Action(Model.IndexAction, Model.Controller)
		   : Url.Action(Model.PageAction, Model.Controller, new
		   {
			   page,
		   });

		return url ??
		   throw new InvalidOperationException(
			  $"Could not generate pager URL for page {page}.");
	}
}

@if (Model.TotalPages > 1)
{
	<nav class="wb-pager mt-4" aria-label="Writing archive pages">
		<ul class="pagination justify-content-center mb-0">
			@if (Model.HasPreviousPage)
			{
				<li class="page-item">
					<a class="page-link" aria-label="Previous page"
					   href="@GetPageUrl(Model.CurrentPage - 1)">
						<i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
					</a>
				</li>
			}
			else
			{
				<li class="page-item disabled">
					<span class="page-link" aria-label="Previous page">
						<i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
					</span>
				</li>
			}

			@if (Model.ShowLeadingEllipsis)
			{
				<li class="page-item disabled">
					<span class="page-link" aria-hidden="true">…</span>
				</li>
			}

			@foreach (var p in Model.VisiblePages)
			{
				if (p == Model.CurrentPage)
				{
					<li class="page-item active">
						<span class="page-link">@p</span>
					</li>
				}
				else
				{
					<li class="page-item">
						<a class="page-link"
						   href="@GetPageUrl(p)">
							@p
						</a>
					</li>
				}
			}

			@if (Model.ShowTrailingEllipsis)
			{
				<li class="page-item disabled">
					<span class="page-link" aria-hidden="true">…</span>
				</li>
			}

			@if (Model.HasNextPage)
			{
				<li class="page-item">
					<a class="page-link" aria-label="Next page"
					   href="@GetPageUrl(Model.CurrentPage + 1)">
						<i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
					</a>
				</li>
			}
			else
			{
				<li class="page-item disabled">
					<span class="page-link" aria-label="Next page">
						<i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
					</span>
				</li>
			}
		</ul>
	</nav>
}