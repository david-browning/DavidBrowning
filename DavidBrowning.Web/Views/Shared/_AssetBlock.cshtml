@model DavidBrowning.Web.ViewModels.AssetBlockViewModel
@inject DavidBrowning.Infrastructure.UrlBuilder urlBuilder

<figure class="wb-asset-block wb-asset-block-image">
	<img src="@urlBuilder.GetContentUrl(Model.AssetKey)"
		 alt="@Model.AltText"
		 loading="lazy"
		 decoding="async" />

	@if (!string.IsNullOrWhiteSpace(Model.Caption))
	{
		<figcaption>@Model.Caption</figcaption>
	}
</figure>
