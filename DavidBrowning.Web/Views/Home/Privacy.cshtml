@model DavidBrowning.Web.ViewModels.Home.PrivacyViewModel
@{
	ViewData["Title"] = Model.Title;
	ViewData["Seo"] = Model.Seo;
}

<section class="wb-hero">
	<div class="container">
		<div class="row g-4 align-items-center">
			<div class="col">
				<p class="wb-kicker">Last updated @Model.LastUpdateDisplayDate</p>
				<h1>@Model.Title</h1>
				<p class="wb-lede">
					@Model.Description
				</p>
			</div>
		</div>
	</div>
</section>

@foreach(var s in Model.Sections)
{
	<section class="wb-section">
		<div class="container">
			<p class="wb-kicker">@s.Subtitle</p>
			<h2>@s.Title</h2>
			<p class="wb-lede">
				@s.Lede
			</p>
		</div>
	</section>
}