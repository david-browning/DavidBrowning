@model DavidBrowning.Web.ViewModels.Home.IndexViewModel
@{
	ViewData["Title"] = Model.PageTitle;
	ViewData["Seo"] = Model.Seo;
}

<section class="wb-hero">
	<div class="container">
		<div class="row g-4 align-items-center">
			<div class="col">
				<p class="wb-kicker">David Browning / Software Engineer</p>
				<h1>@Model.HeroTitle</h1>
				<p class="wb-lede">
					@Model.Lede
				</p>
			</div>
		</div>
	</div>
</section>

<section class="wb-section">
	<div class="container">
		<header class="wb-section-header">
			<p class="wb-kicker">01 / Explore</p>
			<h2>Four ways to explore</h2>
		</header>

		<div class="row row-cols-1 row-cols-lg-4 g-4 align-items-stretch">
			<div class="col">
				<article class="wb-card h-100 d-flex flex-column">
					<h3>
						<i class="fa-solid fa-briefcase"
						   aria-hidden="true"></i>
						Work
					</h3>

					<p class="text-secondary mb-4">
						The professional path: systems shipped, teams supported, and problems solved.
					</p>

					<a class="stretched-link mt-auto"
					   href="/work">
						See my career
					</a>
				</article>
			</div>

			<div class="col">
				<article class="wb-card h-100 d-flex flex-column">
					<h3>
						<i class="fa-solid fa-diagram-project"
						   aria-hidden="true"></i>
						Projects
					</h3>

					<p class="text-secondary mb-4">
						Practical builds, design tradeoffs, and the engineering decisions behind them.
					</p>

					<a class="stretched-link mt-auto"
					   href="/projects">
						Explore projects
					</a>
				</article>
			</div>

			<div class="col">
				<article class="wb-card h-100 d-flex flex-column">
					<h3>
						<i class="fa-solid fa-pen"
						   aria-hidden="true"></i>
						Writing
					</h3>

					<p class="text-secondary mb-4">
						Essays on software, systems, learning, design, and the occasional useful tangent.
					</p>

					<a class="stretched-link mt-auto"
					   href="/writing">
						Read the writing
					</a>
				</article>
			</div>

			<div class="col">
				<article class="wb-card h-100 d-flex flex-column">
					<h3>
						<i class="fa-solid fa-user"
						   aria-hidden="true"></i>
						About
					</h3>

					<p class="text-secondary mb-4">
						The context behind the work: interests, values, background, and what keeps me curious.
					</p>

					<a class="stretched-link mt-auto"
					   href="/about">
						More about me
					</a>
				</article>
			</div>
		</div>
	</div>
</section>

<section class="wb-section">
	<div class="container">
		<header class="wb-section-header">
			<p class="wb-kicker">02 / Featured projects</p>
			<a asp-controller="Projects" class="text-reset text-decoration-none">
				<h2>From the workbench</h2>
			</a>
		</header>
		<div class="row g-4">
			<div class="col">
				<partial name="_FeaturedProjectCard" model="Model.FeaturedProject" />
			</div>
		</div>
		<div class="mt-3">
			<a href="/projects">
				View all projects
				<i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
			</a>
		</div>
	</div>
</section>

<section class="wb-section">
	<div class="container">
		<header class="wb-section-header">
			<p class="wb-kicker">03 / Featured writing</p>
			<a asp-controller="Writing" class="text-reset text-decoration-none">
				<h2>From the notebook</h2>
			</a>
		</header>
		<div class="row g-4">
			<div class="col">
				<partial name="_FeaturedPostCard" model="Model.FeaturedPost" />
			</div>
		</div>
		<div class="mt-3">
			<a href="/writing">
				Browse all writing
				<i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
			</a>
		</div>
	</div>
</section>

<section class="wb-section">
	<div class="container">
		<header class="wb-section-header">
			<p class="wb-kicker">04 / Interests</p>
			<a asp-controller="About" class="text-reset text-decoration-none">
				<h2>On the workbench</h2>
			</a>
		</header>
		<div class="row g-4">
			<div class="col">
				<partial name="_InterestCard" model="Model.WorkbenchInterest" />
			</div>
		</div>
	</div>
</section>