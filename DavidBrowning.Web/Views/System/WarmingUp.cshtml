@*
	Model is the redirect URL.
*@
@model string
@{
	Layout = null;
}

<!doctype html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<meta http-equiv="refresh" content="10;url=@Model" />
	<title>Warming up | David Browning</title>

	<style>
		:root {
			color-scheme: dark;
		}

		body {
			margin: 0;
			min-height: 100vh;
			display: grid;
			place-items: center;
			font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
			background: #0f1217;
			color: #f4f4f5;
		}

		main {
			max-width: 38rem;
			padding: 2rem;
		}

		p {
			color: #a1a1aa;
			line-height: 1.6;
		}

		a {
			color: #f4f4f5;
		}

		.kicker {
			margin-bottom: 0.75rem;
			color: #a1a1aa;
			font-size: 0.8rem;
			font-weight: 700;
			letter-spacing: 0.12em;
			text-transform: uppercase;
		}
	</style>
</head>
<body>
	<main>
		<p class="kicker">Warming up</p>

		<h1>The site is waking up.</h1>

		<p>
			This website uses free Azure hosting, so the app or database may pause
			when nobody has visited for a while. The page you requested will retry
			automatically in a few seconds.
		</p>

		<p>
			<a href="@Model">Try again now</a>
		</p>
	</main>
</body>
</html>