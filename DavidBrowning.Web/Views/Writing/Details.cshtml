@inject TimezoneConverter dateFormatter
@model DavidBrowning.Web.ViewModels.Writing.DetailsViewModel
@{
	ViewData["Title"] = Model.Title;
}

<section class="wb-hero">
	<div class="container">
		<div class="row g-4 align-items-center">
			<div class="col">
				<p class="wb-kicker">@Model.PostStyleDisplayName</p>
				<h1>@Model.Title</h1>
				<p class="wb-lede">@Model.Subtitle</p>
			</div>
		</div>
		<div class="row g-4">
			<div class="col">
				<dl class="mb-0">
					<dt>Published</dt>
					<dd class="text-secondary">
						@if (Model.PublishedDateUtc is not null)
						{
							<time datetime="@Model.PublishedDateUtc.Value.ToString("O")">
								@dateFormatter.FormatDate(Model.PublishedDateUtc.Value)
							</time>
						}
					</dd>
				</dl>
			</div>
			<div class="col">
				<dl class="mb-0">
					<dt>Written by</dt>
					<dd class="text-secondary">@Model.CreatedBy</dd>
				</dl>
			</div>
		</div>
		<div class="row g-4 mt-4">
			<div class="col">
				<aside class="wb-panel wb-panel-accent">
					<p class="wb-card-meta">Tags</p>
					<ul class="wb-tag-list">
						@foreach (var tag in Model.TagLinks)
						{
							var m = new DavidBrowning.Web.ViewModels.QueryTagViewModel()
							{
								Controller = "writing",
								Endpoint = "tags",
								DisplayName = tag.WritingTag!.DisplayName,
								Slug = tag.WritingTag!.Slug,
							};

							<partial name="_QueryTag" model="@m" />
						}
					</ul>
				</aside>
			</div>
		</div>
	</div>
</section>

<section class="wb-section">
	<div class="container">
		<article class="wb-post-body wb-content">
			<partial name="_RenderedContent" model="Model.Body" />
		</article>
	</div>
</section>