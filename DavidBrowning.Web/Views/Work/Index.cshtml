@model DavidBrowning.Web.ViewModels.Work.IndexViewModel
@{
	ViewData["Title"] = Model.PageTitle;
	ViewData["Seo"] = Model.Seo;
}

<section class="wb-hero">
	<div class="container">
		<div class="row g-4 align-items-center">
			<div class="col">
				<p class="wb-kicker">@Model.PageTitle</p>
				<h1>@Model.HeroTitle</h1>
				<p class="wb-lede">
					@Model.Lede
				</p>
			</div>
		</div>
		<div class="d-flex flex-column align-items-start gap-2 mt-4">
			<p class="wb-lede mb-0">
				Download my resume in PDF form.
			</p>

			<a class="btn btn-primary"
			   asp-area="" asp-controller="Work" asp-action="Resume">
				<i class="fa-solid fa-file-pdf me-2" aria-hidden="true"></i>
				<span>Download resume</span>
			</a>
		</div>
	</div>
</section>

<section id="experience" class="wb-section">
	<div class="container">
		<header class="wb-section-header">
			<p class="wb-kicker">01 / Experience</p>
			<h2>Professional experience</h2>
			@* <p class="wb-lede"></p> *@
		</header>
		<div class="row row-cols-1 g-4">
			@foreach (var exp in Model.Experience)
			{
				<partial name="_ExperienceCard" model="exp" />
			}
		</div>
	</div>
</section>

<section id="credentials" class="wb-section">
	<div class="container">
		<header class="wb-section-header">
			<p class="wb-kicker">02 / Background</p>
			<h2>Credentials</h2>
			@* <p class="wb-lede"></p> *@
		</header>
		<div class="row row-cols-1 g-4">
			@foreach (var cred in Model.Credentials)
			{
				<partial name="_CredentialCard" model="cred" />
			}
		</div>
	</div>
</section>

<section id="featured" class="wb-section">
	<div class="container">
		<header class="wb-section-header">
			<p class="wb-kicker">03 / Selected work</p>
			<h2>Featured professional projects</h2>
			@* <p class="wb-lede"></p> *@
		</header>
		<div class="wb-featured-grid">
			@foreach (var project in Model.FeaturedWorkProjects)
			{
				<partial name="_FeaturedProjectCard" model="project" />
			}
		</div>
	</div>
</section>