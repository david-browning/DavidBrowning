{
   "Logging": {
      "LogLevel": {
         "Default": "Information",
         "Microsoft.AspNetCore": "Warning"
      }
   },
   "Stores": {
      "WritingStore": {
         "Provider": "SqlServer"
      },
      "ProjectStore": {
         "Provider": "SqlServer"
      },
      "ErrorStore": {
         "Provider": "SqlServer"
      },
      "LookupStore": {
         "Provider": "SqlServer"
      },
      "ContentStore": {
         "Provider": "Local",
         "LocalRoot": "ContentAssets"
      }
   },
   "Secrets": {
      "Provider": "Local"
   },
   "Database": {
      "Provider": "SqlServer",
      "TablePrefix": "db_",
      "InMemoryDatabaseName": "DavidBrowning",
      "Seed": {
         "Enabled": false,
         "RootFolder": "Data/Seeding/DataFiles",
         "SkipFileWhenTargetTableHasRows": true,
         "ThrowOnUnmatchedJsonFiles": true,
         "UseSqlServerIdentityInsertWhenNeeded": true
      }
   },
   "KeyVault": {
      "Uri": ""
   },
   "Diagnostics": {
      "EnableDebugEndpoints": true,
      "EnableCustomErrors": false,
      "EntityFrameworkOptions": {
         "EnableSensitiveDataLogging": true,
         "EnableDetailedErrors": true,
         "EnableSqlCommandLogging": false
      }
   },
   "DateTimeDisplayOptions": {
      "TimeZoneId": "America/Los_Angeles"
   }
}
