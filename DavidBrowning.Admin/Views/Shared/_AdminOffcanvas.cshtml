@model AdminOffcanvasViewModel

<div class="offcanvas offcanvas-end admin-edit-sidebar"
	 tabindex="-1" id="@Model.Id" aria-labelledby="@Model.TitleId"
	 data-admin-offcanvas data-admin-offcanvas-placeholder="@Model.Placeholder">
	<div class="offcanvas-header border-bottom">
		<h2 class="offcanvas-title h5 mb-0" id="@Model.TitleId">
			@Model.Title
		</h2>

		<button class="btn-close" type="button" data-bs-dismiss="offcanvas"
				aria-label="Close">
		</button>
	</div>

	<div class="offcanvas-body position-relative">
		<div id="@Model.BodyId" data-admin-offcanvas-body>
			<p class="text-secondary mb-0">
				@Model.Placeholder
			</p>
		</div>

		<div id="@Model.OverlayId" class="admin-form-overlay htmx-indicator"
			 role="status" aria-live="polite" aria-label="@Model.LoadingText">
			<div class="spinner-border admin-form-spinner text-primary"
				 aria-hidden="true">
			</div>

			<span class="visually-hidden">
				@Model.LoadingText
			</span>
		</div>
	</div>
</div>