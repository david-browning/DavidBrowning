@using DavidBrowning.Admin.ViewModels
@model DavidBrowning.Admin.ViewModels.ReorderListViewModel
@{
	bool useEditOffcanvas =
	   !string.IsNullOrWhiteSpace(Model.EditOffcanvasId);

	string? editOffcanvasSelector = useEditOffcanvas
	   ? AdminOffcanvasIds.Selector(Model.EditOffcanvasId!)
	   : null;

	string? editOffcanvasBodySelector = useEditOffcanvas
	   ? AdminOffcanvasIds.BodySelector(Model.EditOffcanvasId!)
	   : null;

	string? editOffcanvasOverlaySelector = useEditOffcanvas
	   ? AdminOffcanvasIds.OverlaySelector(Model.EditOffcanvasId!)
	   : null;

	string reorderFormId = $"reorder-form-{Guid.NewGuid():N}";
	string buttonSizeClass = Model.Compact ? "btn-sm" : string.Empty;
	string cardClass = Model.RenderCard ? "card" : string.Empty;
	string cardBodyClass = Model.RenderCard ? "card-body" : string.Empty;

	string itemLayoutClass = Model.Compact
	   ? "d-flex flex-column gap-2"
	   : "d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-2";
}

<section class="@cardClass" data-reorder-list>
	<div class="@cardBodyClass">
		<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center  mb-4">
			<div>
				<h2 class="h4 card-title mb-1">
					@Model.Title
				</h2>

				@if (!string.IsNullOrWhiteSpace(Model.Description))
				{
					<p class="card-text text-secondary mb-0">
						@Model.Description
					</p>
				}
			</div>

			@if (Model.ReoderParameters is not null && Model.Items.Count > 0)
			{
				<button class="btn btn-primary @buttonSizeClass text-nowrap"
						type="submit" form="@reorderFormId" data-reorder-save
						disabled>
					<i class="fa-solid fa-floppy-disk me-1" aria-hidden="true"></i>
					@(Model.Compact ? "Save" : "Save order")
				</button>
			}
		</div>

		@if (Model.Items.Count == 0)
		{
			<div class="alert alert-secondary mb-0"
				 role="status">
				@Model.EmptyMessage
			</div>
		}
		else
		{
			var controller = Model.ReoderParameters is not null ?
			Model.ReoderParameters.ReorderController :
			string.Empty;
			var action = Model.ReoderParameters is not null ?
			Model.ReoderParameters.ReorderAction :
			string.Empty;
			<form id="@reorderFormId" asp-controller="@controller"
				  asp-action="@action" method="post" data-reorder-form>
				<ol class="list-group"
					data-reorder-items>
					@for (var index = 0; index < Model.Items.Count; index++)
					{
						var item = Model.Items[index];
						<li class="list-group-item py-2" data-reorder-item>
							<input type="hidden" name="Items[@index].Id"
								   value="@item.Id" data-reorder-id />
							<input type="hidden" name="Items[@index].SortOrder"
								   value="@item.SortOrder" data-sort-order-input />

							<div class="@itemLayoutClass">
								<div class="flex-grow-1 overflow-hidden">
									<div class="d-flex flex-wrap align-items-center gap-2">
										<h3 class="h6 mb-0">
											@item.DisplayName
										</h3>

										@if (item.IsActive == false)
										{
											<span class="badge text-bg-secondary">
												Hidden
											</span>
										}
									</div>

									@if (!string.IsNullOrWhiteSpace(item.SecondaryText))
									{
										<div class="small text-secondary text-truncate">
											@item.SecondaryText
										</div>
									}
								</div>

								<div class="d-flex flex-wrap justify-content-end align-items-center gap-1">
									@if (Model.ReoderParameters is not null)
									{
										<div class="btn-group btn-group-sm"
											 role="group"
											 aria-label="Change display order for @item.DisplayName">
											<button class="btn btn-outline-secondary"
													type="button" data-reorder-direction="up"
													aria-label="Move @item.DisplayName up">
												<i class="fa-solid fa-arrow-up"
												   aria-hidden="true"></i>
											</button>

											<button class="btn btn-outline-secondary"
													type="button" data-reorder-direction="down"
													aria-label="Move @item.DisplayName down">
												<i class="fa-solid fa-arrow-down"
												   aria-hidden="true"></i>
											</button>
										</div>
									}

									<a class="btn btn-outline-primary @buttonSizeClass"
									   asp-controller="@item.EditController"
									   asp-action="@item.EditAction"
									   asp-route-id="@item.Id"
									   hx-boost="@(useEditOffcanvas ? null : "false")"
									   hx-get="@(useEditOffcanvas? Url.Action(item.EditAction, item.EditController, new { id = item.Id }) : null)"
									   hx-target="@editOffcanvasBodySelector"
									   hx-swap="@(useEditOffcanvas ? "innerHTML" : null)"
									   hx-indicator="@editOffcanvasOverlaySelector"
									   data-bs-toggle="@(useEditOffcanvas ? "offcanvas" : null)"
									   data-bs-target="@editOffcanvasSelector"
									   aria-controls="@(useEditOffcanvas? Model.EditOffcanvasId: null)">
										<i class="fa-solid fa-pen" aria-hidden="true"></i>
									</a>

									<button class="btn btn-outline-danger @buttonSizeClass"
											type="submit" form="delete-item-@item.Id"
											data-delete-button aria-label="Delete @item.DisplayName">
										<i class="fa-solid fa-trash" aria-hidden="true"></i>
									</button>
								</div>
							</div>
						</li>
					}
				</ol>
			</form>

			@foreach (var item in Model.Items)
			{
				<form asp-controller="@item.DeleteController"
					  asp-action="@item.DeleteAction" method="post"
					  id="delete-item-@item.Id" data-delete-form
					  data-delete-name="@item.DisplayName">
					<input type="hidden" name="Id" value="@item.Id" />
				</form>
			}
		}
	</div>
</section>