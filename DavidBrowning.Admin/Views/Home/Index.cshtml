@model DavidBrowning.Admin.ViewModels.Home.IndexViewModel

@{
	ViewData["Title"] = "Dashboard";
}

<div class="mb-4">
	<h1>Dashboard</h1>
	<p class="text-muted mb-0">
		Manage the content published on davidbrowning.com.
	</p>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
	<div class="col">
		<div class="card h-100">
			<div class="card-body">
				<h2 class="h5 card-title">Writing</h2>
				<p class="card-text">
					Edit posts, revisions, tags, and publication details.
				</p>
			</div>
			<div class="card-footer bg-transparent">
				<a class="btn btn-primary" asp-controller="Writing" asp-action="Index">
					Manage writing
				</a>
			</div>
		</div>
	</div>
	
	<div class="col">
		<div class="card h-100">
			<div class="card-body">
				<h2 class="h5 card-title">Projects</h2>
				<p class="card-text">
					Edit projects, links, tags, stack entries, and related content.
				</p>
			</div>
			<div class="card-footer bg-transparent">
				<a class="btn btn-primary" asp-controller="Projects" asp-action="Index">
					Manage projects
				</a>
			</div>
		</div>
	</div>

	<div class="col">
		<div class="card h-100">
			<div class="card-body">
				<h2 class="h5 card-title">Work</h2>
				<p class="card-text">
					Edit credentials, experience, roles, and role details.
				</p>
			</div>
			<div class="card-footer bg-transparent">
				<a class="btn btn-primary" asp-controller="Work" asp-action="Index">
					Manage work history
				</a>
			</div>
		</div>
	</div>

	<div class="col">
		<div class="card h-100">
			<div class="card-body">
				<h2 class="h5 card-title">About</h2>
				<p class="card-text">
					Edit personal information, interests, and related content.
				</p>
			</div>
			<div class="card-footer bg-transparent">
				<a class="btn btn-primary" asp-controller="About" asp-action="Index">
					Manage about page
				</a>
			</div>
		</div>
	</div>

	<div class="col">
		<div class="card h-100">
			<div class="card-body">
				<h2 class="h5 card-title">Assets</h2>
				<p class="card-text">
					Upload, inspect, replace, and remove site assets.
				</p>
			</div>
			<div class="card-footer bg-transparent">
				<a class="btn btn-primary" asp-controller="Asset" asp-action="Index">
					Manage assets
				</a>
			</div>
		</div>
	</div>

	<div class="col">
		<div class="card h-100">
			<div class="card-body">
				<h2 class="h5 card-title">Errors</h2>
				<p class="card-text">
					Website error history
				</p>
			</div>
			<div class="card-footer bg-transparent">
				<a class="btn btn-primary" asp-controller="Error" asp-action="Index">
					Review Errors
				</a>
			</div>
		</div>
	</div>
</div>
