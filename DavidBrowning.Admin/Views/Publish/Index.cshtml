@using DavidBrowning.Admin.ViewModels.Publish
@model IndexViewModel

@{
	ViewData["Title"] = "Publish";
}

<header class="mb-4">
	<h1>Publishing</h1>
	<p class="text-secondary">
		Publish site content from the database to Blob Storage.
	</p>
</header>

@if (!string.IsNullOrWhiteSpace(Model.ResultMessage))
{
	string alertClass = Model.ResultStatus switch
	{
		PublishResultStatus.Success => "alert-success",
		PublishResultStatus.Error => "alert-danger",
		_ => "alert-secondary",
	};

	string alertRole =
		Model.ResultStatus == PublishResultStatus.Error
			? "alert"
			: "status";

	<div class="alert @alertClass" role="@alertRole">
		@Model.ResultMessage
	</div>
}

<div class="row g-4">
	<div class="col-12 col-xl-5">
		<div class="card">
			<div class="card-body">
				<h2 class="h5 card-title">Publish public content</h2>
				<p class="card-text text-secondary">
					Build a complete public-site snapshot and update the
					current publication manifest.
				</p>

				<form asp-controller="Publish" asp-action="Publish" method="post">
					<button type="submit" class="btn btn-primary">
						Publish site
					</button>
				</form>
			</div>
		</div>
	</div>

	<div class="col-12 col-xl-7">
		<div class="card">
			<div class="card-body">
				<h2 class="h5 card-title">Publication status</h2>
				<p class="card-text text-secondary">
					Publication history and snapshot statistics will
					eventually appear here.
				</p>
			</div>
		</div>
	</div>
</div>