@model IReadOnlyList<DavidBrowning.Models.Error.WebsiteError>
@using DavidBrowning.Admin.ViewModels
@using DavidBrowning.Admin.ViewModels.Error
@{
	ViewData["Title"] = "Website errors";
}

<div class="d-flex flex-column flex-md-row
            justify-content-between align-items-md-center
            gap-3 mb-4">
	<div>
		<h1 class="mb-1">Website errors</h1>
		<p class="text-muted mb-0">
			Review unhandled application errors captured by the website.
		</p>
	</div>

	<span class="badge text-bg-secondary align-self-start">
		@Model.Count error@(Model.Count == 1 ? string.Empty : "s")
	</span>
</div>

@if (Model.Count == 0)
{
	<div class="alert alert-success" role="alert">
		No website errors have been recorded.
	</div>
}
else
{
	<div class="table-responsive">
		<table class="table table-striped table-hover align-middle">
			<thead>
				<tr>
					<th scope="col">Occurred</th>
					<th scope="col"
						class="d-none d-lg-table-cell">
						Environment
					</th>
					<th scope="col"
						class="d-none d-md-table-cell">
						Request
					</th>
					<th scope="col"
						class="d-none d-xl-table-cell">
						Status
					</th>
					<th scope="col">Error</th>
					<th scope="col"
						class="d-none d-sm-table-cell">
						Handled
					</th>
					<th scope="col">
						<span class="visually-hidden">Actions</span>
					</th>
				</tr>
			</thead>

			<tbody>
				@foreach (var error in Model)
				{
					<tr>
						<td class="text-nowrap">
							<time datetime="@error.OccurredAtUtc.ToString("O")">
								@error.OccurredAtUtc.ToString("yyyy-MM-dd HH:mm:ss")
							</time>
							<div class="small text-muted">UTC</div>
						</td>

						<td class="d-none d-lg-table-cell">
							@(string.IsNullOrWhiteSpace(error.EnvironmentName)
												? "—"
												: error.EnvironmentName)
				</td>

						<td class="d-none d-md-table-cell">
							<div class="text-nowrap">
								@if (!string.IsNullOrWhiteSpace(error.HttpMethod))
								{
									<span class="badge text-bg-secondary me-1 text-info">
										@error.HttpMethod
									</span>
								}

							<span class="text-break">
								@(string.IsNullOrWhiteSpace(error.Path)
															? "—"
															: error.Path)
						</span>
					</div>
				</td>

						<td class="d-none d-xl-table-cell">
							@(error.StatusCode?.ToString() ?? "—")
						</td>

						<td>
							<div class="fw-semibold text-break">
								@error.ExceptionType
							</div>

							<div class="small text-muted text-break">
								@error.ExceptionMessage
							</div>

							@if (!string.IsNullOrWhiteSpace(error.Path))
							{
								<div class="small text-muted text-break d-md-none mt-1">
									@error.Path
								</div>
							}
						</td>

						<td class="d-none d-sm-table-cell">
							@if (error.IsHandled)
							{
								<span class="badge text-bg-success text-info">Yes</span>
							}
							else
							{
								<span class="badge text-bg-warning text-info">No</span>
							}
						</td>

						<td class="text-end">
							<a class="btn btn-sm btn-outline-primary"
							   asp-controller="Error" asp-action="Details"
							   asp-route-id="@error.Id"
							   hx-get="@Url.Action("Details", "Error", new { id = error.Id })"
							   hx-target="@AdminOffcanvasIds.BodySelector(ErrorAdminIds.ErrorDetailsOffcanvas)"
							   hx-swap="innerHTML"
							   hx-indicator="@AdminOffcanvasIds.OverlaySelector(ErrorAdminIds.ErrorDetailsOffcanvas)"
							   data-bs-toggle="offcanvas"
							   data-bs-target="@AdminOffcanvasIds.Selector(ErrorAdminIds.ErrorDetailsOffcanvas)"
							   aria-controls="@ErrorAdminIds.ErrorDetailsOffcanvas">
								Details
							</a>
						</td>
					</tr>
				}
			</tbody>
		</table>
	</div>
}