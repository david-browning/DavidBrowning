@model DavidBrowning.Admin.ViewModels.Writing.WritingTagEditViewModel
@using DavidBrowning.Admin.Controllers
@using DavidBrowning.Admin.ViewModels
@using DavidBrowning.Admin.ViewModels.Writing

<form asp-controller="Writing" asp-action="TagEdit" method="post"
	  hx-post="@Url.Action(nameof(WritingController.TagEdit), "Writing")"
	  hx-target="@AdminOffcanvasIds.BodySelector(WritingAdminIds.TagEditOffcanvas)"
	  hx-swap="innerHTML"
	  hx-disabled-elt="find fieldset"
	  hx-indicator="@AdminOffcanvasIds.OverlaySelector(WritingAdminIds.TagEditOffcanvas)">
	<fieldset>
		<div asp-validation-summary="ModelOnly"
			 class="alert alert-danger"
			 role="alert">
		</div>

		<input asp-for="Id" type="hidden" />

		<div class="mb-3">
			<label asp-for="DisplayName" class="form-label"></label>
			<input asp-for="DisplayName" class="form-control" autocomplete="off" />
			<span asp-validation-for="DisplayName" class="text-danger"></span>
		</div>

		<div class="mb-3">
			<label asp-for="Slug" class="form-label"></label>
			<input asp-for="Slug" class="form-control" autocomplete="off" />
			<span asp-validation-for="Slug" class="text-danger"></span>
		</div>

		<div class="d-flex gap-2">
			<button class="btn btn-primary" type="submit">
				Save tag
			</button>

			<button class="btn btn-outline-secondary"
					type="button"
					data-bs-dismiss="offcanvas">
				Close
			</button>
		</div>
	</fieldset>
</form>