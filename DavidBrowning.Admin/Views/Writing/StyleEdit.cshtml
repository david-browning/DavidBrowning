@model DavidBrowning.Admin.ViewModels.Writing.PostStyleEditViewModel
@using DavidBrowning.Admin.Controllers
@using DavidBrowning.Admin.ViewModels
@using DavidBrowning.Admin.ViewModels.Writing
@{
	bool isEditMode = Model.EditMode == EditModes.Edit;
	string formAction = isEditMode ? nameof(WritingController.StyleEdit) :
			nameof(WritingController.StyleCreate);
	string htmxTarget = isEditMode ?
	  AdminOffcanvasIds.BodySelector(WritingAdminIds.StyleEditOffcanvas) :
	  $"#{WritingAdminIds.StyleCreateRegion}";
	string overlaySelector = isEditMode ?
	  AdminOffcanvasIds.OverlaySelector(WritingAdminIds.StyleEditOffcanvas) :
	  $"#{WritingAdminIds.StyleCreateOverlay}";
}

<div class="admin-form-region">
	<form asp-controller="Writing" asp-action="@formAction" method="post"
		  data-slug-editor
		  hx-post="@Url.Action(formAction, "Writing")"
		  hx-target="@htmxTarget"
		  hx-swap="innerHTML"
		  hx-disabled-elt="find fieldset"
		  hx-indicator="@overlaySelector">
		<fieldset>
			<div asp-validation-summary="ModelOnly"
				 class="alert alert-danger" role="alert">
			</div>

			@if (isEditMode)
			{
				<input asp-for="Id" type="hidden" />
			}

			<div class="mb-3">
				<label asp-for="DisplayName" class="form-label"></label>
				<input asp-for="DisplayName" class="form-control"
					   data-slug-source autocomplete="off" />
				<span asp-validation-for="DisplayName" class="text-danger"></span>
			</div>

			<div class="mb-3">
				<label asp-for="Slug" class="form-label"></label>
				<input asp-for="Slug" class="form-control"
					   data-slug-target autocomplete="off" />
				<span asp-validation-for="Slug" class="text-danger"></span>
			</div>

			<div class="mb-3">
				<label asp-for="Description" class="form-label"></label>
				<textarea asp-for="Description" class="form-control" rows="3"></textarea>
				<span asp-validation-for="Description" class="text-danger"></span>
			</div>

			<div class="form-check mb-3">
				<input asp-for="IsActive" class="form-check-input" type="checkbox" />
				<label asp-for="IsActive" class="form-check-label">
					Available for posts
				</label>
			</div>

			<div class="d-flex gap-2">
				<button class="btn btn-primary" type="submit">
					Submit
				</button>

				@if (isEditMode)
				{
					<button class="btn btn-outline-secondary"
							type="button" data-bs-dismiss="offcanvas">
						Cancel
					</button>
				}
				else
				{
					<a class="btn btn-outline-secondary"
					   asp-controller="Writing" asp-action="Index">
						Reset
					</a>
				}
			</div>
		</fieldset>
	</form>
	@if (!isEditMode)
	{
		<div id="@WritingAdminIds.StyleCreateOverlay"
			 class="admin-form-overlay htmx-indicator"
			 role="status" aria-live="polite" aria-label="Saving style">
			<partial name="_Waiting" />
		</div>
	}
</div>