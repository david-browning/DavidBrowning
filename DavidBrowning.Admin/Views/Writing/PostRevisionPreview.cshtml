@model DavidBrowning.Models.RenderedContent?
@using DavidBrowning.Admin.ViewModels.Writing

<section class="card h-100">
	<div class="card-body">
		<div class="d-flex justify-content-between align-items-start gap-3 mb-3">
			<div>
				<h3 class="h5 card-title mb-1">
					Preview
				</h3>
				<p class="card-text text-secondary mb-0">
					Render the current draft before saving a new revision.
				</p>
			</div>

			<button class="btn btn-sm btn-outline-primary text-nowrap"
					type="button"
					hx-post="@Url.Action("PostRevisionPreview", "Writing")"
					hx-include="[data-post-revision-editor-form]"
					hx-target="#@WritingAdminIds.PostRevisionPreviewBodyRegion"
					hx-swap="innerHTML">
				Update preview
			</button>
		</div>

		<div id="@WritingAdminIds.PostRevisionPreviewBodyRegion">
			<partial name="PostRevisionPreviewBody" model="Model" />
		</div>
	</div>
</section>