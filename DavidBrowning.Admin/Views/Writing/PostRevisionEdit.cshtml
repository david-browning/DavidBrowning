@model DavidBrowning.Admin.ViewModels.Writing.Posts.PostRevisionContentViewModel
@using DavidBrowning.Admin.ViewModels
@using DavidBrowning.Admin.ViewModels.Writing
@using DavidBrowning.Models

<section class="card">
    <div class="card-body position-relative">
        <div id="@WritingAdminIds.PostRevisionContentOverlay"
             class="admin-form-overlay d-none"
             aria-hidden="true">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Saving revision</span>
            </div>
        </div>

        <div class="d-flex flex-column flex-lg-row justify-content-between
                  align-items-lg-start gap-3 mb-4">
            <div>
                <h2 class="h4 card-title mb-1">
                    @if (Model.EditMode == EditModes.Edit)
                    {
                        <text>Revision @Model.RevisionNumber</text>
                    }
                    else
                    {
                        <text>New revision</text>
                    }
                </h2>

                @if (Model.EditMode == EditModes.Edit)
                {
                    <p class="card-text text-secondary mb-0">
                        Loaded from revision @Model.RevisionNumber.
                        Saving creates a new revision.
                    </p>
                }
                else
                {
                    <p class="card-text text-secondary mb-0">
                        Create a new content snapshot for this post.
                    </p>
                }
            </div>

            <div class="d-flex flex-wrap gap-2">
                @if (Model.IsCurrentRevision)
                {
                    <span class="badge text-bg-success align-self-start">
                        Current revision
                    </span>
                }

                @if (Model.CreatedAtUtc.HasValue)
                {
                    <span class="badge text-bg-secondary align-self-start">
                        @Model.CreatedAtUtc.Value.ToString("yyyy-MM-dd HH:mm")
                    </span>
                }
            </div>
        </div>

        <form method="post"
              asp-controller="Writing"
              asp-action="PostRevisionCreate"
              hx-post="@Url.Action("PostRevisionCreate", "Writing")"
              hx-target="#@WritingAdminIds.PostRevisionContentRegion"
              hx-swap="innerHTML"
              hx-indicator="#@WritingAdminIds.PostRevisionContentOverlay">
            @Html.AntiForgeryToken()

            <fieldset>
                <input asp-for="PostId" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3">
                </div>

                <div class="mb-3">
                    <label asp-for="ContentFormat" class="form-label"></label>
                    <select asp-for="ContentFormat"
                            asp-items="Html.GetEnumSelectList<ContentFormat>()"
                            class="form-select">
                    </select>
                    <span asp-validation-for="ContentFormat"
                          class="text-danger">
                    </span>
                </div>

                <div class="mb-3">
                    <label asp-for="Content" class="form-label"></label>
                    <textarea asp-for="Content"
                              class="form-control font-monospace"
                              rows="22" spellcheck="true"></textarea>
                    <span asp-validation-for="Content"
                          class="text-danger">
                    </span>
                </div>

                <div class="d-flex flex-column flex-sm-row gap-2">
                    <button class="btn btn-primary" type="submit">
                        Save as new revision
                    </button>

                    @if (Model.EditMode == EditModes.Edit)
                    {
                        <span class="text-secondary align-self-sm-center">
                            This will not overwrite revision @Model.RevisionNumber.
                        </span>
                    }
                </div>
            </fieldset>
        </form>
    </div>
</section>