@model PostListViewModel

<section class="card">
   <div class="card-body">
      <div class="d-flex flex-column flex-sm-row justify-content-between
                  align-items-sm-center gap-3 mb-4">
         <div>
            <h2 class="h4 card-title mb-1">Posts</h2>
            <p class="card-text text-secondary mb-0">
               Open a post to edit its metadata, tags, and revision history.
            </p>
         </div>

         <a class="btn btn-primary text-nowrap"
            asp-controller="Writing" asp-action="PostIndex">
            <i class="fa-solid fa-plus me-1" aria-hidden="true"></i>
            Create post
         </a>
      </div>

      @if (Model.Items.Count == 0)
      {
         <div class="alert alert-secondary mb-0" role="status">
            No posts have been created.
         </div>
      }
      else
      {
         <div class="list-group">
            @foreach (var post in Model.Items.OrderByDescending(
               post => post.LastUpdatedDateUtc))
            {
               <a class="list-group-item list-group-item-action"
                  asp-controller="Writing" asp-action="PostEdit"
                  asp-route-id="@post.Id">
                  <div class="d-flex flex-column flex-md-row
                              justify-content-between gap-2">
                     <div class="overflow-hidden">
                        <div class="d-flex flex-wrap align-items-center gap-2">
                           <h3 class="h5 mb-0">@post.Title</h3>
                           <span class="badge text-bg-secondary">@post.Status</span>
                           @if (post.IsFeatured)
                           {
                              <span class="badge text-bg-primary">Featured</span>
                           }
                        </div>

                        @if (!string.IsNullOrWhiteSpace(post.Subtitle))
                        {
                           <p class="mb-1 mt-2">@post.Subtitle</p>
                        }

                        <div class="small text-secondary text-break">
                           /writing/@post.Slug
                        </div>
                     </div>

                     <div class="small text-secondary text-md-end flex-shrink-0">
                        <div>@post.StyleDisplayName</div>
                        <div>
                           @post.RevisionCount revision@(post.RevisionCount == 1 ? "" : "s"),
                           @post.TagCount tag@(post.TagCount == 1 ? "" : "s")
                        </div>
                        <div>Updated @post.LastUpdatedDateUtc.ToString("yyyy-MM-dd")</div>
                     </div>
                  </div>
               </a>
            }
         </div>
      }
   </div>
</section>
