@model DavidBrowning.Admin.ViewModels.Writing.WritingTagEditViewModel
@using DavidBrowning.Admin.Controllers
@using DavidBrowning.Admin.ViewModels.Writing

<div class="admin-form-region">
	<form asp-controller="Writing" asp-action="TagCreate" method="post"
		  hx-post="@Url.Action(nameof(WritingController.TagCreate), "Writing")"
		  hx-target="#@WritingAdminIds.TagCreateRegion"
		  hx-swap="innerHTML"
		  hx-disabled-elt="find fieldset"
		  hx-indicator="#@WritingAdminIds.TagCreateOverlay">
		<fieldset>
			<div asp-validation-summary="ModelOnly"
				 class="alert alert-danger"
				 role="alert">
			</div>

			<div class="mb-3">
				<label asp-for="DisplayName" class="form-label"></label>
				<input asp-for="DisplayName" class="form-control" autocomplete="off" />
				<span asp-validation-for="DisplayName" class="text-danger"></span>
			</div>

			<div class="mb-3">
				<label asp-for="Slug" class="form-label"></label>
				<input asp-for="Slug" class="form-control" autocomplete="off" />
				<span asp-validation-for="Slug" class="text-danger"></span>
			</div>

			<button class="btn btn-primary" type="submit">
				<i class="fa-solid fa-plus me-1" aria-hidden="true"></i>
				Add tag
			</button>
		</fieldset>
	</form>

	<div id="@WritingAdminIds.TagCreateOverlay"
		 class="admin-form-overlay htmx-indicator"
		 role="status"
		 aria-live="polite"
		 aria-label="Saving writing tag">
		<partial name="_Waiting" />
	</div>
</div>