@model DavidBrowning.Models.RenderedContent?
@using DavidBrowning.Admin.ViewModels.Projects

<section class="card h-100">
	<div class="card-body">
		<div class="d-flex justify-content-between align-items-start gap-3 mb-3">
			<div>
				<h2 class="h4 card-title mb-1">
					Preview
				</h2>
				<p class="card-text text-secondary mb-0">
					Render the current project details before saving.
				</p>
			</div>

			<button class="btn btn-sm btn-outline-primary text-nowrap"
					type="button"
					hx-post="@Url.Action("ProjectContentPreview", "Projects")"
					hx-include="[data-project-content-editor-form]"
					hx-target="#@ProjectAdminIds.ProjectPreviewBodyRegion"
					hx-swap="innerHTML">
				Update preview
			</button>
		</div>

		<div id="@ProjectAdminIds.ProjectPreviewBodyRegion">
			<partial name="ProjectPreviewBody" model="Model" />
		</div>
	</div>
</section>
