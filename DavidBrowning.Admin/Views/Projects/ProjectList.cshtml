@model DavidBrowning.Admin.ViewModels.Projects.ProjectListViewModel

<section class="card">
	<div class="card-body">
		<div class="d-flex justify-content-between align-items-start gap-3 mb-3">
			<div>
				<h2 class="h4 card-title mb-1">
					Projects
				</h2>
				<p class="card-text text-secondary mb-0">
					Create, edit, and order portfolio projects.
				</p>
			</div>

			<form method="post" asp-controller="Projects" asp-action="ProjectCreate">
				@Html.AntiForgeryToken()
				<a class="btn btn-primary" asp-controller="Projects" asp-action="ProjectCreate">
					New project
				</a>
			</form>
		</div>

		@if (Model.Items.Count == 0)
		{
			<div class="alert alert-secondary mb-0" role="status">
				No projects have been created.
			</div>
		}
		else
		{
			<div class="list-group">
				@foreach (var project in Model.Items)
				{
					<a class="list-group-item list-group-item-action"
					   asp-controller="Projects" asp-action="ProjectEdit"
					   asp-route-id="@project.Id">
						<div class="d-flex justify-content-between gap-3">
							<div>
								<div class="fw-semibold">
									@project.Name
								</div>

								<div class="small text-secondary">
									@project.Slug
								</div>

								<div class="small text-secondary">
									@project.Status · @project.Origin · @project.Type ·
									@project.Visibility
								</div>
							</div>

							@if (project.IsFeatured)
							{
								<span class="badge text-bg-primary align-self-start">
									Featured
								</span>
							}
						</div>
					</a>
				}
			</div>
		}
	</div>
</section>