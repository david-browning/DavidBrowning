@model DavidBrowning.Admin.ViewModels.Projects.ProjectLookupEditViewModel
@using DavidBrowning.Admin.ViewModels.Projects
@using DavidBrowning.Admin.ViewModels

<form method="post"
	  asp-controller="Projects"
	  asp-action="@Model.FormAction"
	  hx-post="@Url.Action(Model.FormAction, "Projects")"
	  hx-target="@AdminOffcanvasIds.BodySelector(ProjectAdminIds.ProjectLookupEditorOffcanvas)"
	  hx-swap="innerHTML">
	@Html.AntiForgeryToken()
	@if (Model.Id is not null)
	{
		<input asp-for="Id" type="hidden" />
	}

	<div asp-validation-summary="ModelOnly" class="text-danger mb-3">
	</div>

	<div class="mb-3">
		<label asp-for="DisplayName" class="form-label"></label>
		<input asp-for="DisplayName" class="form-control" data-slug-source />
		<span asp-validation-for="DisplayName" class="text-danger"></span>
	</div>

	<div class="mb-3">
		<label asp-for="Slug" class="form-label"></label>
		<input asp-for="Slug" class="form-control" data-slug-target />
		<span asp-validation-for="Slug" class="text-danger"></span>
	</div>

	<div class="mb-3">
		<label asp-for="Description" class="form-label"></label>
		<textarea asp-for="Description" class="form-control" rows="4"></textarea>
		<span asp-validation-for="Description" class="text-danger"></span>
	</div>

	<div class="mb-3">
		<label asp-for="SortOrder" class="form-label"></label>
		<input asp-for="SortOrder" class="form-control" type="number" />
	</div>

	<div class="form-check mb-4">
		<input asp-for="IsActive" class="form-check-input" />
		<label asp-for="IsActive" class="form-check-label"></label>
	</div>

	<button class="btn btn-primary" type="submit">
		Save
	</button>
</form>