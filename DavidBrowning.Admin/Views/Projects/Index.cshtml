@model DavidBrowning.Admin.ViewModels.Projects.ProjectAdminIndexViewModel
@using DavidBrowning.Admin.ViewModels.Projects

@{
	ViewData["Title"] = "Projects";
}

<div class="container py-4">
	<header class="mb-4">
		<h1>Projects</h1>
		<p class="text-secondary mb-0">
			Manage project metadata, lookup values, and portfolio entries.
		</p>
	</header>

	<div class="d-grid gap-4">
		<section>
			<div class="row g-4">
				<div class="col-12 col-xl-4">
					<partial name="ProjectLookupPanel" model="Model.Statuses" />
				</div>

				<div class="col-12 col-xl-4">
					<partial name="ProjectLookupPanel" model="Model.Origins" />
				</div>

				<div class="col-12 col-xl-4">
					<partial name="ProjectLookupPanel" model="Model.Types" />
				</div>

				<div class="col-12 col-xl-4">
					<partial name="ProjectLookupPanel" model="Model.Visibilities" />
				</div>

				<div class="col-12 col-xl-4">
					<partial name="ProjectLookupPanel" model="Model.Tags" />
				</div>

				<div class="col-12 col-xl-4">
					<partial name="ProjectLookupPanel" model="Model.StackTags" />
				</div>
			</div>
		</section>

		<section class="card">
			<div class="card-body">
				<div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-4">
					<div>
						<h2 class="h4 card-title mb-1">
							Projects
						</h2>
						<p class="card-text text-secondary mb-0">
							Create, edit, and order portfolio projects.
						</p>
					</div>

					<div class="text-md-end">
						<a class="btn btn-primary" asp-controller="Projects"
						   asp-action="ProjectCreate">
							New project
						</a>
					</div>
				</div>

				<div id="@ProjectAdminIds.ProjectListRegion">
					<partial name="_ReorderList" model="Model.Projects" />
				</div>
			</div>
		</section>
	</div>
	<partial name="_AdminOffcanvas" model="Model.LookupEditorOffcanvas" />
</div>