@model DavidBrowning.Admin.ViewModels.Projects.ProjectLookupPanelViewModel

<section class="card h-100">
	<div class="card-body">
		<div class="d-flex justify-content-between align-items-start gap-3 mb-3">
			<div>
				<h2 class="h5 card-title mb-1">
					@Model.Title
				</h2>
				<p class="card-text text-secondary mb-0">
					@Model.Description
				</p>
			</div>

			<button class="btn btn-sm btn-primary text-nowrap"
					type="button"
					hx-get="@Url.Action(Model.CreateAction, "Projects")"
					hx-target="#@Model.RegionId"
					hx-swap="innerHTML">
				Add
			</button>
		</div>

		<div id="@Model.RegionId">
			@if (Model.Items.Count == 0)
			{
				<div class="alert alert-secondary mb-0" role="status">
					No items have been created.
				</div>
			}
			else
			{
				<div class="list-group">
					@foreach (var item in Model.Items)
					{
						<div class="list-group-item">
							<div class="d-flex justify-content-between gap-3">
								<div>
									<div class="fw-semibold">
										@item.DisplayName
									</div>
									<div class="small text-secondary">
										@item.Slug
									</div>
								</div>

								@if (!item.IsActive)
								{
									<span class="badge text-bg-secondary align-self-start">
										Inactive
									</span>
								}
							</div>
						</div>
					}
				</div>
			}
		</div>
	</div>
</section>