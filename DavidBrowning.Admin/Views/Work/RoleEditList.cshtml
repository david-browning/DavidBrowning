@model DavidBrowning.Admin.ViewModels.Work.Experience.RoleEditListViewModel
@using DavidBrowning.Admin.ViewModels.Work

<section class="card">
	<div class="card-body">
		<h2 class="h4 card-title">
			Roles
		</h2>

		<p class="card-text text-secondary">
			Add positions held at this company and arrange their display order.
		</p>

		<div id="@WorkAdminIds.RoleCreateRegion">
			<partial name="RoleCreate" model="Model.Create" />
		</div>

		<div id="@WorkAdminIds.RoleListRegion"
			 class="mt-4"
			 hx-boost="true"
			 hx-target="#@WorkAdminIds.RoleListRegion"
			 hx-swap="innerHTML">
			<partial name="_ReorderList" model="Model.Roles" />
		</div>
	</div>
</section>