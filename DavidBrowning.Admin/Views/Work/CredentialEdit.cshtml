@model DavidBrowning.Admin.ViewModels.Work.Credentials.EditViewModel
@using DavidBrowning.Admin.Controllers
@using DavidBrowning.Admin.ViewModels
@using DavidBrowning.Admin.ViewModels.Work
@{
	bool isEditMode = Model.EditMode == EditModes.Edit;
	string formAction = isEditMode ? nameof(WorkController.CredentialEdit) :
			nameof(WorkController.CredentialCreate);
	string htmxTarget = isEditMode ?
				AdminOffcanvasIds.BodySelector(WorkAdminIds.CredentialEditOffcanvas) :
				$"#{WorkAdminIds.CredentialCreateRegion}";
	string overlaySelector = isEditMode ?
				AdminOffcanvasIds.OverlaySelector(WorkAdminIds.CredentialEditOffcanvas) :
				$"#{WorkAdminIds.CredentialCreateOverlay}";

	string editorId = Model.EditMode == EditModes.Edit ?
				$"credential-edit-{Model.Id}" : $"credential-create";
}

<section class="card">
	<div class="card-body">
		<h2 class="card-title">
			@(isEditMode ? "Edit credential" : "Create credential")
		</h2>
		@if (isEditMode)
		{
			<p class="card-text text-secondary">
				Edit @Model.Name credential
			</p>
		}
		else
		{
			<p class="card-text text-secondary">
				New credential
			</p>
		}
		<div class="admin-form-region">
			<form method="post" asp-controller="Work" asp-action="@formAction"
				  data-credential-edit-form
				  data-asset-edit-mode="@isEditMode.ToString().ToLowerInvariant()"
				  hx-post="@Url.Action(formAction, "Work")" hx-target="@htmxTarget"
				  hx-swap="innerHTML" hx-disabled-elt="find fieldset"
				  hx-indicator="@overlaySelector"
				  enctype="multipart/form-data" hx-encoding="multipart/form-data">
				<fieldset data-asset-upload-form>
					<div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert">
					</div>

					@if (isEditMode)
					{
						<input asp-for="Id" type="hidden" />
					}

					<div class="row mb-3">
						<div class="col-12">
							<label asp-for="Name" class="form-label"></label>
							<input asp-for="Name" class="form-control" autocomplete="off" />
							<span asp-validation-for="Name" class="text-danger"></span>
						</div>
					</div>

					<div class="row mb-3">
						<div class="col-12 col-md-6">
							<label asp-for="IssuingOrganization" class="form-label"></label>
							<input asp-for="IssuingOrganization" class="form-control"
								   list="issuing-organization-options" autocomplete="off" />
							<datalist id="issuing-organization-options">
								<option value="Microsoft"></option>
								<option value="HCL"></option>
								<option value="California Polytechnic State University"></option>
								<option value="Bellevue College"></option>
							</datalist>
							<span asp-validation-for="IssuingOrganization" class="text-danger">
							</span>
						</div>

						<div class="col-12 col-md-6">
							<label asp-for="Type" class="form-label"></label>
							<input asp-for="Type" class="form-control"
								   list="credential-type-options" autocomplete="off" />
							<datalist id="credential-type-options">
								<option value="Degree"></option>
								<option value="Certificate"></option>
								<option value="Certification"></option>
								<option value="Award"></option>
								<option value="License"></option>
							</datalist>
							<span asp-validation-for="Type" class="text-danger">
							</span>
						</div>
					</div>

					<div class="row mb-3">
						<div class="col-12 col-md-6">
							<label asp-for="AwardedMonth" class="form-label">
							</label>
							<select asp-for="AwardedMonth" class="form-select"
									data-awarded-month>
								<option value="">Select month</option>
								<option value="1">January</option>
								<option value="2">February</option>
								<option value="3">March</option>
								<option value="4">April</option>
								<option value="5">May</option>
								<option value="6">June</option>
								<option value="7">July</option>
								<option value="8">August</option>
								<option value="9">September</option>
								<option value="10">October</option>
								<option value="11">November</option>
								<option value="12">December</option>
							</select>
							<span asp-validation-for="AwardedMonth" class="text-danger">
							</span>
						</div>

						<div class="col-12 col-md-6">
							<label asp-for="AwardedYear" class="form-label">
							</label>
							<input asp-for="AwardedYear" class="form-control" type="number"
								   min="1" max="9999" inputmode="numeric"
								   data-awarded-year />
							<span asp-validation-for="AwardedYear" class="text-danger">
							</span>
						</div>
					</div>

					<div class="mb-3">
						<label asp-for="DateDisplayText" class="form-label">
						</label>
						<input asp-for="DateDisplayText" class="form-control"
							   type="text" placeholder="Example: June 2026"
							   data-awarded-date-display />
						<span asp-validation-for="DateDisplayText" class="text-danger">
						</span>
					</div>

					<div class="mb-3">
						<label asp-for="Description" class="form-label">
						</label>
						<textarea asp-for="Description" class="form-control" rows="4">
						</textarea>
						<span asp-validation-for="Description" class="text-danger">
						</span>
					</div>

					<div class="mb-3">
						<label asp-for="CredentialUrl" class="form-label">
						</label>
						<input asp-for="CredentialUrl" class="form-control"
							   type="url" inputmode="url"
							   placeholder="https://example.com/credential" />
						<span asp-validation-for="CredentialUrl" class="text-danger">
						</span>
					</div>

					<div class="form-check mb-3">
						<input asp-for="IsActive" class="form-check-input" type="checkbox" />
						<label asp-for="IsActive" class="form-check-label">
						</label>
					</div>

					<div class="row mb-3">
						<div class="col-12">
							<div class="d-flex gap-2">
								<button class="btn btn-primary" type="submit">
									Submit
								</button>
								@if (isEditMode)
								{
									<button class="btn btn-outline-secondary"
											type="button" data-bs-dismiss="offcanvas">
										Close
									</button>
								}
								else
								{
									<a class="btn btn-outline-secondary"
									   asp-controller="Work" asp-action="CredentialIndex">
										Reset
									</a>
								}
							</div>
						</div>
					</div>
				</fieldset>
			</form>
			@if (!isEditMode)
			{
				<div id="@WorkAdminIds.CredentialCreateOverlay"
					 class="admin-form-overlay htmx-indicator"
					 role="status" aria-live="polite" aria-label="Saving credential">
					<partial name="_Waiting" />
				</div>
			}
		</div>
	</div>
</section>