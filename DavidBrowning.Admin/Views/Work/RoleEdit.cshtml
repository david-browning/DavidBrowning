@model DavidBrowning.Admin.ViewModels.Work.Experience.RoleEditViewModel
@using DavidBrowning.Admin.Controllers
@using DavidBrowning.Admin.ViewModels.Work
@using DavidBrowning.Admin.ViewModels.Work.Experience

@{
	ViewData["Title"] = "Edit role";

	var bulletCreateModel = new RoleBulletEditViewModel()
	{
		ExperienceRoleId = Model.Id,
	};
}

<div class="container py-4">
	<header class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-4">
		<div>
			<h1>
				Edit role
			</h1>

			<p class="text-secondary mb-0">
				Update the role details and manage its bullets.
			</p>
		</div>

		<div class="flex-shrink-0">
			<a class="btn btn-outline-secondary" asp-controller="Work"
			   asp-action="ExperienceEdit" asp-route-id="@Model.ExperienceId">
				Back to experience
			</a>
		</div>
	</header>

	<div class="row g-4 align-items-start">
		<div class="col-12 col-xl-5">
			<section class="card">
				<div class="card-body">
					<h2 class="h4 card-title">
						Role details
					</h2>

					<p class="card-text text-secondary">
						Update the title, dates, description, and visibility for this role.
					</p>

					<form method="post"
						  asp-controller="Work"
						  asp-action="RoleEdit">
						<fieldset>
							<div asp-validation-summary="ModelOnly"
								 class="alert alert-danger" role="alert">
							</div>

							<input asp-for="Id" type="hidden" />
							<input asp-for="ExperienceId" type="hidden" />

							<div class="row g-3">
								<div class="col-12">
									<label asp-for="Title" class="form-label"></label>
									<input asp-for="Title" class="form-control" autocomplete="off" />
									<span asp-validation-for="Title" class="text-danger"></span>
								</div>

								<div class="col-12">
									<label asp-for="DateDisplayText" class="form-label"></label>
									<input asp-for="DateDisplayText" class="form-control"
										   autocomplete="off" placeholder="Example: 2019–2025" />
									<span asp-validation-for="DateDisplayText" class="text-danger"></span>
								</div>

								<div class="col-12">
									<label asp-for="Description" class="form-label"></label>
									<textarea asp-for="Description" class="form-control" rows="3"></textarea>
									<span asp-validation-for="Description" class="text-danger"></span>
								</div>

								<div class="col-12">
									<div class="form-check">
										<input asp-for="IsActive" class="form-check-input"
											   type="checkbox" />
										<label asp-for="IsActive" class="form-check-label">
											Show on work page
										</label>
									</div>
								</div>

								<div class="col-12">
									<div class="d-flex flex-wrap gap-2">
										<button class="btn btn-primary" type="submit">
											Save role
										</button>

										<a class="btn btn-outline-secondary"
										   asp-controller="Work" asp-action="ExperienceEdit"
										   asp-route-id="@Model.ExperienceId">
											Back to experience
										</a>
									</div>
								</div>
							</div>
						</fieldset>
					</form>
				</div>
			</section>
		</div>

		<div class="col-12 col-xl-7">
			<section class="card">
				<div class="card-body">
					<h2 class="h4 card-title">
						Bullets
					</h2>

					<p class="card-text text-secondary">
						Add résumé-style bullets for this role and remove bullets that no longer apply.
					</p>

					<div id="@WorkAdminIds.RoleBulletCreateRegion">
						<partial name="RoleBulletCreate" model="bulletCreateModel" />
					</div>

					<div id="@WorkAdminIds.RoleBulletListRegion" class="mt-4">
						<partial name="RoleBulletList" model="Model" />
					</div>
				</div>
			</section>
		</div>
	</div>
</div>