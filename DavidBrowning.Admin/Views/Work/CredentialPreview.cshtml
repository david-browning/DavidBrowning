@model IReadOnlyList<DavidBrowning.Admin.ViewModels.Work.Credentials.PreviewViewModel>

<section class="card h-100">
	<div class="card-body d-flex flex-column">
		<h2>Credentials</h2>

		<p class="card-text text-secondary">
			Set credentials, awards, and education.
		</p>

		<p>
			@Model.Count credential@(Model.Count == 1 ? string.Empty : "s")
		</p>

		<div class="mt-auto">
			<a class="btn btn-primary" asp-controller="Work" asp-action="CredentialIndex">
				<i class="fa-solid fa-award" aria-hidden="true"></i>
				Manage credentials
			</a>
		</div>
	</div>
</section>